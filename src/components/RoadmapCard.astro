---
import type { Roadmap } from '../lib/db';
import { Brain, Code2, Award, ChevronRight, Play, BookOpen } from '@lucide/astro';

interface Props {
  roadmap: Roadmap;
}

const { roadmap } = Astro.props;
---

<div class="glass-panel rounded-2xl p-6 md:p-8 flex flex-col justify-between h-full hover:border-white/15 transition-all duration-300">
  <div>
    <!-- Title & Icon -->
    <div class="flex items-start gap-4 mb-4">
      <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent shadow-[0_0_15px_rgba(109,94,247,0.15)]">
        {roadmap.icon === 'Brain' ? <Brain class="w-6 h-6" /> : <Code2 class="w-6 h-6" />}
      </div>
      
      <div>
        <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted">Curated Learning Path</span>
        <h3 class="text-lg font-bold tracking-tight text-white mt-0.5">{roadmap.title}</h3>
      </div>
    </div>

    <!-- Description -->
    <p class="text-xs text-text-secondary leading-relaxed mb-6">
      {roadmap.description}
    </p>

    <!-- Path Steps timeline -->
    <div class="relative pl-6 border-l border-white/5 space-y-6 mb-8">
      {roadmap.steps.map((step, idx) => (
        <div class="relative">
          <!-- Step indicator dot -->
          <span class="absolute -left-[30px] top-1.5 w-3 h-3 rounded-full border-2 border-black bg-accent flex items-center justify-center shadow-[0_0_5px_#6d5ef7]"></span>
          
          <div class="flex flex-col gap-1">
            <span class="text-[10px] font-mono uppercase tracking-wider text-accent font-semibold">
              Step {idx + 1}: {step.title}
            </span>
            <p class="text-xs text-zinc-300 leading-snug">{step.description}</p>
            <a 
              href={`/playlist/${step.recommendedPlaylistSlug}`} 
              class="text-[10px] text-text-secondary hover:text-white hover:underline font-mono mt-1 flex items-center gap-1"
            >
              <BookOpen class="w-3 h-3 text-accent" /> Recommended: {step.recommendedPlaylistSlug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Start Learning Path CTA -->
  <div class="border-t border-white/5 pt-4">
    <a 
      href={`/playlist/${roadmap.steps[0].recommendedPlaylistSlug}`}
      class="w-full py-2.5 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold flex items-center justify-center gap-1.5 transition-all cursor-pointer shadow-lg hover:scale-[0.98]"
    >
      <Play class="w-3.5 h-3.5 fill-black" /> Begin Learning Track
    </a>
  </div>
</div>
