---
import type { ScoreBreakdown } from '../lib/db';
import { Info, HelpCircle } from '@lucide/astro';

interface Props {
  score: number;
  breakdown?: ScoreBreakdown;
  size?: 'sm' | 'md' | 'lg';
  showBreakdown?: boolean;
}

const { score, breakdown, size = 'md', showBreakdown = false } = Astro.props;

// Determine status text/color based on score
const getGradeInfo = (val: number) => {
  if (val >= 95) return { label: 'Elite Tier', border: 'border-accent/40', text: 'text-accent', bg: 'bg-accent/5' };
  if (val >= 90) return { label: 'Top Tier', border: 'border-indigo-500/40', text: 'text-indigo-400', bg: 'bg-indigo-950/20' };
  if (val >= 80) return { label: 'Highly Rated', border: 'border-emerald-500/40', text: 'text-emerald-400', bg: 'bg-emerald-950/20' };
  return { label: 'Recommended', border: 'border-zinc-700', text: 'text-zinc-300', bg: 'bg-zinc-900/40' };
};

const grade = getGradeInfo(score);

const sizeClasses = {
  sm: {
    circle: 'w-10 h-10 text-base',
    text: 'text-xs',
    container: 'gap-2'
  },
  md: {
    circle: 'w-14 h-14 text-xl',
    text: 'text-sm',
    container: 'gap-3'
  },
  lg: {
    circle: 'w-24 h-24 text-3xl',
    text: 'text-base',
    container: 'gap-6'
  }
};

const sizes = sizeClasses[size];

// SVG circle measurements for radial ring
const radius = size === 'lg' ? 40 : size === 'md' ? 24 : 16;
const strokeWidth = size === 'lg' ? 6 : size === 'md' ? 4 : 3;
const circumference = 2 * Math.PI * radius;
const strokeDashoffset = circumference - (score / 100) * circumference;
---

<div class={`flex items-center ${sizes.container}`}>
  <!-- Radial Circle -->
  <div class="relative flex items-center justify-center font-mono font-bold">
    <svg class={`${size === 'lg' ? 'w-24 h-24' : size === 'md' ? 'w-14 h-14' : 'w-10 h-10'} -rotate-90`}>
      <!-- Background Circle -->
      <circle
        cx="50%"
        cy="50%"
        r={radius}
        fill="transparent"
        stroke="rgba(255, 255, 255, 0.05)"
        stroke-width={strokeWidth}
      />
      <!-- Active Progress Circle -->
      <circle
        cx="50%"
        cy="50%"
        r={radius}
        fill="transparent"
        stroke={score >= 90 ? '#6d5ef7' : '#818cf8'}
        stroke-width={strokeWidth}
        stroke-dasharray={circumference}
        stroke-dashoffset={strokeDashoffset}
        stroke-linecap="round"
        class="transition-all duration-1000 ease-out"
      />
    </svg>
    <div class="absolute flex flex-col items-center justify-center">
      <span class="text-white tracking-tighter">{score}</span>
    </div>
  </div>

  <!-- Label and Grade description -->
  <div class="flex flex-col">
    <span class={`font-mono text-[10px] uppercase tracking-wider font-semibold ${grade.text}`}>
      {grade.label}
    </span>
    <span class="text-xs text-text-muted">Quality Score</span>
  </div>
</div>

{showBreakdown && breakdown && (
  <div class="mt-6 p-4 rounded-xl border border-white/5 bg-zinc-950/40 backdrop-blur-md w-full">
    <div class="flex items-center justify-between mb-4 border-b border-white/5 pb-2">
      <h4 class="text-xs font-mono uppercase tracking-wider text-white flex items-center gap-1.5">
        <Info class="w-3.5 h-3.5 text-accent" /> Score Breakdown
      </h4>
      <span class="text-[10px] font-mono text-text-muted">Weighted Formula</span>
    </div>
    
    <div class="space-y-3">
      {/* User Reviews: 35% */}
      <div class="space-y-1">
        <div class="flex justify-between text-xs font-mono">
          <span class="text-text-secondary">User Reviews (35%)</span>
          <span class="text-white font-semibold">{breakdown.userReviews}/100</span>
        </div>
        <div class="w-full h-1.5 bg-zinc-900 rounded-full overflow-hidden">
          <div class="h-full bg-accent rounded-full" style={`width: ${breakdown.userReviews}%`}></div>
        </div>
      </div>

      {/* Completion Rate: 25% */}
      <div class="space-y-1">
        <div class="flex justify-between text-xs font-mono">
          <span class="text-text-secondary">Completion Rate (25%)</span>
          <span class="text-white font-semibold">{breakdown.completionRate}/100</span>
        </div>
        <div class="w-full h-1.5 bg-zinc-900 rounded-full overflow-hidden">
          <div class="h-full bg-accent/80 rounded-full" style={`width: ${breakdown.completionRate}%`}></div>
        </div>
      </div>

      {/* Playlist Structure: 20% */}
      <div class="space-y-1">
        <div class="flex justify-between text-xs font-mono">
          <span class="text-text-secondary">Playlist Structure (20%)</span>
          <span class="text-white font-semibold">{breakdown.playlistStructure}/100</span>
        </div>
        <div class="w-full h-1.5 bg-zinc-900 rounded-full overflow-hidden">
          <div class="h-full bg-accent/60 rounded-full" style={`width: ${breakdown.playlistStructure}%`}></div>
        </div>
      </div>

      {/* Recent Activity: 10% */}
      <div class="space-y-1">
        <div class="flex justify-between text-xs font-mono">
          <span class="text-text-secondary">Recent Activity (10%)</span>
          <span class="text-white font-semibold">{breakdown.recentActivity}/100</span>
        </div>
        <div class="w-full h-1.5 bg-zinc-900 rounded-full overflow-hidden">
          <div class="h-full bg-accent/40 rounded-full" style={`width: ${breakdown.recentActivity}%`}></div>
        </div>
      </div>

      {/* Creator Authority: 10% */}
      <div class="space-y-1">
        <div class="flex justify-between text-xs font-mono">
          <span class="text-text-secondary">Creator Authority (10%)</span>
          <span class="text-white font-semibold">{breakdown.creatorAuthority}/100</span>
        </div>
        <div class="w-full h-1.5 bg-zinc-900 rounded-full overflow-hidden">
          <div class="h-full bg-accent/20 rounded-full" style={`width: ${breakdown.creatorAuthority}%`}></div>
        </div>
      </div>
    </div>
  </div>
)}
