---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  schema?: Record<string, any> | Array<Record<string, any>>;
  ogType?: string;
}

const { 
  title = "youtubeplaylistfinder | Free YouTube Playlist Finder", 
  description = "Discover the absolute best study and educational YouTube playlists. We mathematically rank, review, and score playlists to help you find structured learning paths instantly.",
  canonical,
  robots = "index, follow",
  schema,
  ogType = "website"
} = Astro.props;

// Determine current canonical url
const defaultCanonical = new URL(Astro.url.pathname, "https://youtubeplaylistfinder.com").toString();
const activeCanonical = canonical || defaultCanonical;

// Default Website & Organization schemas
const baseWebsiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "youtubeplaylistfinder",
  "url": "https://youtubeplaylistfinder.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://youtubeplaylistfinder.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "youtubeplaylistfinder",
  "url": "https://youtubeplaylistfinder.com",
  "logo": "https://youtubeplaylistfinder.com/favicon-96x96.png",
  "sameAs": []
};

// Combine schema list
const schemaList = [];
if (schema) {
  if (Array.isArray(schema)) {
    schemaList.push(...schema);
  } else {
    schemaList.push(schema);
  }
} else {
  schemaList.push(baseWebsiteSchema, organizationSchema);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-01EM1V8RB9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-01EM1V8RB9');
    </script>
    
    <!-- Google AdSense -->
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6852093563333288" crossorigin="anonymous"></script>
    
    <!-- Favicon Links -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ListsEasy" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <meta name="generator" content={Astro.generator} />
    
    <!-- Meta robots and canonicals -->
    <meta name="robots" content={robots} />
    <link rel="canonical" href={activeCanonical} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={activeCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://images.unsplash.com/photo-1527474305487-b87b222841cc?q=80&w=1200&auto=format&fit=crop" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={activeCanonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://images.unsplash.com/photo-1527474305487-b87b222841cc?q=80&w=1200&auto=format&fit=crop" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

    <!-- Structured Data Schema Markup -->
    {schemaList.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s).replace(/</g, '\\u003c').replace(/>/g, '\\u003e')} />
    ))}
  </head>
  <body class="min-h-screen bg-black text-white relative selection:bg-white selection:text-black antialiased gradient-mesh">
    <!-- Header -->
    <Header />
    
    <!-- Main Content Grid -->
    <main class="w-full max-w-7xl mx-auto px-6 md:px-12 py-8 relative z-10">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Cookie Consent Banner -->
    <div id="cookie-consent-banner" class="fixed bottom-6 right-6 z-50 max-w-sm w-[calc(100vw-3rem)] glass-panel bg-zinc-950/90 backdrop-blur-xl border border-white/10 p-5 rounded-2xl shadow-2xl space-y-4 hidden animate-in fade-in slide-in-from-bottom-5 duration-300">
      <div class="flex items-start gap-3">
        <div class="p-2 rounded-lg bg-accent/10 border border-accent/20 text-accent shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <div class="space-y-1">
          <h4 class="text-xs font-bold text-white uppercase tracking-wider font-mono">Cookie Consent</h4>
          <p class="text-[11px] text-text-secondary leading-relaxed">This website uses cookies and YouTube Data API Services to improve user experience.</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-2 pt-2 border-t border-white/5">
        <button id="accept-cookies-btn" class="flex-1 py-2 px-3 rounded-lg bg-white hover:bg-zinc-200 text-black text-[10px] font-semibold transition-all cursor-pointer text-center">Accept</button>
        <button id="decline-cookies-btn" class="py-2 px-3 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-white/5 text-text-secondary text-[10px] font-semibold transition-all cursor-pointer text-center">Decline Analytics</button>
        <a href="/privacy" class="w-full py-1.5 text-center text-[10px] text-text-muted hover:text-white font-mono transition-colors">Learn More</a>
      </div>
    </div>

    <!-- YouTube API Disclosure Banner -->
    <div id="api-disclosure-banner" class="fixed bottom-6 left-6 z-50 max-w-sm w-[calc(100vw-3rem)] glass-panel bg-zinc-950/90 backdrop-blur-xl border border-white/10 p-5 rounded-2xl shadow-2xl space-y-4 hidden animate-in fade-in slide-in-from-bottom-5 duration-300">
      <div class="flex items-start gap-3">
        <div class="p-2 rounded-lg bg-red-500/10 border border-red-500/20 text-red-500 shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="space-y-1">
          <h4 class="text-xs font-bold text-white uppercase tracking-wider font-mono">API Disclosure</h4>
          <p class="text-[11px] text-text-secondary leading-relaxed">This application uses YouTube API Services. By continuing you agree to Google's Privacy Policy and YouTube Terms of Service.</p>
        </div>
      </div>
      <div class="flex gap-2 pt-2 border-t border-white/5">
        <button id="dismiss-api-btn" class="flex-1 py-2 px-3 rounded-lg bg-white hover:bg-zinc-200 text-black text-[10px] font-semibold transition-all cursor-pointer text-center">Dismiss</button>
        <a href="/privacy" class="flex-1 py-2 px-3 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-white/5 text-text-secondary text-[10px] font-semibold transition-all cursor-pointer text-center">Learn More</a>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // Cookie Consent Banner Check
        const cookieBanner = document.getElementById('cookie-consent-banner');
        const acceptCookiesBtn = document.getElementById('accept-cookies-btn');
        const declineCookiesBtn = document.getElementById('decline-cookies-btn');

        if (cookieBanner && acceptCookiesBtn && declineCookiesBtn) {
          const consent = localStorage.getItem('cookieConsent');
          if (!consent) {
            cookieBanner.classList.remove('hidden');
          }

          acceptCookiesBtn.addEventListener('click', () => {
            localStorage.setItem('cookieConsent', 'accepted');
            cookieBanner.classList.add('hidden');
          });

          declineCookiesBtn.addEventListener('click', () => {
            localStorage.setItem('cookieConsent', 'declined');
            cookieBanner.classList.add('hidden');
          });
        }

        // API Disclosure Banner Check
        const apiBanner = document.getElementById('api-disclosure-banner');
        const dismissApiBtn = document.getElementById('dismiss-api-btn');

        if (apiBanner && dismissApiBtn) {
          const apiDismissed = localStorage.getItem('youtubeApiDisclosure');
          if (!apiDismissed) {
            apiBanner.classList.remove('hidden');
          }

          dismissApiBtn.addEventListener('click', () => {
            localStorage.setItem('youtubeApiDisclosure', 'dismissed');
            apiBanner.classList.add('hidden');
          });
        }
      });
    </script>
  </body>
</html>
