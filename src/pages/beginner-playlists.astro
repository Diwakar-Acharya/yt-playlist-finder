---
import Layout from '../layouts/Layout.astro';
import PlaylistCard from '../components/PlaylistCard.astro';
import { searchPlaylists } from '../lib/api';
import { getCloudflareEnv } from '../lib/youtube';
import { Layers } from '@lucide/astro';

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

// Fetch and validate playlists on server
const playlists = await searchPlaylists('', { difficulty: 'Beginner' }, 'best', apiKey, env);

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Beginner Playlists", "item": "https://youtubeplaylistfinder.com/beginner-playlists" }
  ]
};
---

<Layout 
  title="Best Beginner YouTube Playlists - Intro courses | youtubeplaylistfinder"
  description="Discover scored introductory YouTube playlists for beginners. Start learning from scratch with easy checks, clear checklists, and foundations guides."
  canonical="https://youtubeplaylistfinder.com/beginner-playlists"
  schema={breadcrumbs}
>
  <div class="space-y-12">
    <!-- Header -->
    <section class="border-b border-white/5 pb-6">
      <div class="flex items-center gap-2">
        <Layers class="w-5 h-5 text-emerald-400" />
        <div>
          <span class="text-[10px] font-mono uppercase tracking-wider text-emerald-400 font-semibold">Introductory Level</span>
          <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Beginner-Friendly Courses</h1>
        </div>
      </div>
      <p class="text-xs text-text-secondary mt-2">Study guides structured specifically for absolute beginners, teaching core foundations clearly.</p>
    </section>

    <!-- Listings Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.map(playlist => (
        <PlaylistCard playlist={playlist} />
      ))}
    </div>
  </div>
</Layout>
