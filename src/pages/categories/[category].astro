---
import Layout from '../../layouts/Layout.astro';
import { searchPlaylists } from '../../lib/api';
import { ArrowLeft } from '@lucide/astro';

const { category } = Astro.params;
if (!category) {
  return Astro.redirect('/404');
}

// Map slug categories to search terms
const keywordMap: Record<string, { term: string; label: string; desc: string }> = {
  programming: {
    term: 'programming',
    label: 'Programming & Development',
    desc: 'Ranked video courses on core coding languages, web frameworks, system design, and database architectures.'
  },
  exams: {
    term: 'exam',
    label: 'Exams & Admissions',
    desc: 'Structured curricula to prepare for competitive examinations and college test courses.'
  },
  science: {
    term: 'science',
    label: 'Academic Science',
    desc: 'Master fundamentals of science, chemistry outlines, physics models, and college math lectures.'
  },
  technology: {
    term: 'machine learning',
    label: 'Emerging Technology',
    desc: 'Deep-dive tracks covering artificial intelligence models, cloud servers, and DevOps tooling.'
  }
};

const details = keywordMap[category.toLowerCase()] || {
  term: category,
  label: category.charAt(0).toUpperCase() + category.slice(1),
  desc: `Ranked and scored YouTube playlists matching the category ${category}.`
};

const playlists = await searchPlaylists(details.term);

// Breadcrumbs
const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Categories", "item": "https://youtubeplaylistfinder.com/categories" },
    { "@type": "ListItem", "position": 3, "name": details.label, "item": `https://youtubeplaylistfinder.com/categories/${category}` }
  ]
};

const getDifficultyBadge = (diff: string) => {
  if (diff === 'Beginner') return 'border-emerald-500/20 text-emerald-400 bg-emerald-950/10';
  if (diff === 'Intermediate') return 'border-yellow-500/20 text-yellow-400 bg-yellow-950/10';
  return 'border-red-500/20 text-red-400 bg-red-950/10';
};
---

<Layout 
  title={`${details.label} Playlists - youtubeplaylistfinder`}
  description={details.desc}
  canonical={`https://youtubeplaylistfinder.com/categories/${category}`}
  schema={breadcrumbs}
>
  <div class="space-y-8">
    <!-- Back to Category index -->
    <div>
      <a href="/categories" class="inline-flex items-center gap-1 text-xs text-text-secondary hover:text-white transition-colors">
        <ArrowLeft class="w-4 h-4" /> Back to Categories index
      </a>
    </div>

    <section class="border-b border-white/5 pb-6">
      <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted font-semibold">Category Segment</span>
      <h1 class="text-3xl font-bold tracking-tight text-white mt-1">{details.label}</h1>
      <p class="text-xs text-text-secondary mt-1">{details.desc}</p>
    </section>

    <!-- Playlist list grids -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.length === 0 ? (
        <div class="col-span-full py-16 text-center border border-dashed border-white/5 rounded-2xl">
          <h3 class="text-sm font-semibold text-white">No playlists cataloged for {details.label}</h3>
          <p class="text-xs text-text-muted mt-1">We couldn't locate any matching courses right now.</p>
        </div>
      ) : (
        playlists.map(playlist => (
          <div class="group glass-panel rounded-2xl overflow-hidden glass-panel-hover flex flex-col justify-between h-full relative">
            <div class="relative w-full aspect-video overflow-hidden border-b border-white/5 bg-zinc-950">
              <img src={playlist.thumbnail} alt={playlist.title} class="w-full h-full object-cover opacity-75 group-hover:scale-105 group-hover:opacity-90 transition-all duration-300" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
              
              <div class="absolute bottom-3 left-3 flex items-center gap-2 z-10">
                <span class="px-2.5 py-0.5 rounded-full bg-black/75 border border-white/5 text-[10px] font-mono text-white flex items-center gap-1">
                  {playlist.videoCount} videos
                </span>
                <span class="px-2.5 py-0.5 rounded-full bg-black/75 border border-white/5 text-[10px] font-mono text-white flex items-center gap-1">
                  {playlist.durationHours} hours
                </span>
              </div>
            </div>

            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <a href={`/creator/${encodeURIComponent(playlist.channel)}`} class="text-[10px] font-mono uppercase tracking-wider text-zinc-500 hover:text-white transition-colors">{playlist.channel}</a>
                <h2 class="text-base font-bold tracking-tight text-white line-clamp-2 mt-1 leading-snug group-hover:text-accent transition-colors">
                  <a href={`/playlist/${playlist.slug}`}>{playlist.title}</a>
                </h2>
                <p class="text-xs text-zinc-400 line-clamp-2 leading-relaxed mt-2 mb-4">{playlist.description}</p>
              </div>

              <div class="border-t border-white/5 pt-4 flex items-center justify-between">
                <!-- Score Indicator -->
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full border border-accent/20 bg-accent/5 flex items-center justify-center font-mono font-bold text-xs text-white">
                    {playlist.score}
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[8px] uppercase tracking-wider text-accent font-semibold font-mono">Score</span>
                    <span class="text-[10px] text-zinc-500 leading-none">Quality</span>
                  </div>
                </div>

                <span class={`text-[9px] uppercase px-2 py-0.5 rounded border ${getDifficultyBadge(playlist.difficulty)}`}>
                  {playlist.difficulty}
                </span>
              </div>
            </div>

            <div class="px-6 pb-6 pt-2 flex gap-3">
              <a href={`/playlist/${playlist.slug}`} class="flex-1 py-2 px-4 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold flex items-center justify-center gap-1.5 transition-all shadow-lg text-center">
                Start Learning
              </a>
            </div>
          </div>
        ))
      )}
    </div>
  </div>
</Layout>
