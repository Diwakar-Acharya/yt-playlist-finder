---
import Layout from '../../layouts/Layout.astro';
import PlaylistCard from '../../components/PlaylistCard.astro';
import { searchPlaylists } from '../../lib/api';
import { getCloudflareEnv } from '../../lib/youtube';
import { ArrowLeft } from '@lucide/astro';

const { category } = Astro.params;
if (!category) {
  return Astro.redirect('/404');
}

// Map slug categories to search terms
const keywordMap: Record<string, { term: string; label: string; desc: string }> = {
  programming: {
    term: 'programming',
    label: 'Programming & Development',
    desc: 'Ranked video courses on core coding languages, web frameworks, system design, and database architectures.'
  },
  exams: {
    term: 'exam',
    label: 'Exams & Admissions',
    desc: 'Structured curricula to prepare for competitive examinations and college test courses.'
  },
  science: {
    term: 'science',
    label: 'Academic Science',
    desc: 'Master fundamentals of science, chemistry outlines, physics models, and college math lectures.'
  },
  technology: {
    term: 'machine learning',
    label: 'Emerging Technology',
    desc: 'Deep-dive tracks covering artificial intelligence models, cloud servers, and DevOps tooling.'
  }
};

const details = keywordMap[category.toLowerCase()] || {
  term: category,
  label: category.charAt(0).toUpperCase() + category.slice(1),
  desc: `Ranked and scored YouTube playlists matching the category ${category}.`
};

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

const playlists = await searchPlaylists(details.term, {}, 'best', apiKey, env);

// Breadcrumbs
const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Categories", "item": "https://youtubeplaylistfinder.com/categories" },
    { "@type": "ListItem", "position": 3, "name": details.label, "item": `https://youtubeplaylistfinder.com/categories/${category}` }
  ]
};
---

<Layout 
  title={`${details.label} Playlists - youtubeplaylistfinder`}
  description={details.desc}
  canonical={`https://youtubeplaylistfinder.com/categories/${category}`}
  schema={breadcrumbs}
>
  <div class="space-y-8">
    <!-- Back to Category index -->
    <div>
      <a href="/categories" class="inline-flex items-center gap-1 text-xs text-text-secondary hover:text-white transition-colors">
        <ArrowLeft class="w-4 h-4" /> Back to Categories index
      </a>
    </div>

    <section class="border-b border-white/5 pb-6">
      <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted font-semibold">Category Segment</span>
      <h1 class="text-3xl font-bold tracking-tight text-white mt-1">{details.label}</h1>
      <p class="text-xs text-text-secondary mt-1">{details.desc}</p>
    </section>

    <!-- Playlist list grids -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.length === 0 ? (
        <div class="col-span-full py-16 text-center border border-dashed border-white/5 rounded-2xl">
          <h3 class="text-sm font-semibold text-white">No playlists cataloged for {details.label}</h3>
          <p class="text-xs text-text-muted mt-1">We couldn't locate any matching courses right now.</p>
        </div>
      ) : (
        playlists.map(playlist => (
          <PlaylistCard playlist={playlist} />
        ))
      )}
    </div>
  </div>
</Layout>
