---
import Layout from '../../layouts/Layout.astro';
import { Compass, Code2, GraduationCap, Atom, Cpu } from '@lucide/astro';

const list = [
  { name: 'Programming & Development', slug: 'programming', desc: 'Code structures, algorithms, databases, web development, and DevOps outlines.', count: 5, icon: Code2 },
  { name: 'Exams & Admissions', slug: 'exams', desc: 'Test preparation, college courses, competitive syllabi, and structural mock outlines.', count: 3, icon: GraduationCap },
  { name: 'Academic Science', slug: 'science', desc: 'Chemistry formulas, physics lectures, biology, and scientific math lessons.', count: 2, icon: Atom },
  { name: 'Emerging Technology', slug: 'technology', desc: 'Machine Learning algorithms, AI prompt tools, cybersecurity systems, and data pipelines.', count: 4, icon: Cpu }
];

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Categories", "item": "https://youtubeplaylistfinder.com/categories" }
  ]
};
---

<Layout 
  title="Browse Learning Categories - Curation Catalog | youtubeplaylistfinder"
  description="Select a learning category to find ranked YouTube playlists. Explore programming, exams, chemistry, and system technologies."
  canonical="https://youtubeplaylistfinder.com/categories"
  schema={breadcrumbs}
>
  <div class="space-y-12">
    <!-- Header -->
    <section class="border-b border-white/5 pb-6">
      <div class="flex items-center gap-2">
        <Compass class="w-5 h-5 text-accent" />
        <div>
          <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted">Curation Categories</span>
          <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Learning Portals</h1>
        </div>
      </div>
      <p class="text-xs text-text-secondary mt-2">Browse scored collections grouped logically to eliminate course decision fatigue.</p>
    </section>

    <!-- Grid Menu -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {list.map(c => {
        const IconComponent = c.icon;
        return (
          <a href={`/categories/${c.slug}`} class="group glass-panel border border-white/5 rounded-3xl p-8 hover:border-white/10 hover:bg-zinc-900/40 transition-all flex flex-col justify-between text-left">
            <div>
              <div class="w-10 h-10 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent mb-6 group-hover:scale-105 transition-transform">
                <IconComponent class="w-5 h-5" />
              </div>
              <h2 class="text-lg font-bold text-white group-hover:text-accent transition-colors">{c.name}</h2>
              <p class="text-xs text-text-secondary leading-relaxed mt-2">{c.desc}</p>
            </div>
            <span class="text-[10px] font-mono text-zinc-500 uppercase mt-6 block">{c.count} Scored Playlists →</span>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
