---
import Layout from '../../layouts/Layout.astro';
import { searchPlaylists } from '../../lib/api';
import { ChevronLeft, CheckCircle2 } from '@lucide/astro';

const { creator } = Astro.params;
if (!creator) {
  return Astro.redirect('/404');
}

const cleanCreator = decodeURIComponent(creator);

// Fetch playlists by searching for the creator name to capture live scraping support
const playlists = await searchPlaylists(cleanCreator);
const filteredPlaylists = playlists.filter(p => 
  p.channel.toLowerCase().includes(cleanCreator.toLowerCase())
);

// Breadcrumb Schema
const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Creators", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 3, "name": cleanCreator, "item": `https://youtubeplaylistfinder.com/creator/${creator}` }
  ]
};
---

<Layout 
  title={`Best YouTube Playlists by ${cleanCreator} (Ranked & Scored) | youtubeplaylistfinder`}
  description={`Browse and search all educational YouTube playlists created by ${cleanCreator}. View Quality Scores, structure analysis, and dynamic roadmaps.`}
  canonical={`https://youtubeplaylistfinder.com/creator/${creator}`}
  schema={breadcrumbs}
>
  <div class="space-y-8">
    <div>
      <a href="/" class="inline-flex items-center gap-1 text-xs text-text-secondary hover:text-white transition-colors">
        <ChevronLeft class="w-4 h-4" /> Back to search
      </a>
    </div>

    <!-- Creator Header Info -->
    <section class="glass-panel border border-white/5 rounded-3xl p-6 md:p-10 mb-8 relative overflow-hidden">
      <div class="absolute -right-16 -top-16 w-36 h-36 rounded-full bg-accent/15 blur-3xl pointer-events-none"></div>
      
      <div class="relative z-10 space-y-3">
        <span class="px-2.5 py-0.5 rounded-full border border-accent/30 bg-accent/5 text-[9px] font-mono text-accent font-semibold uppercase tracking-wider">
          Creator Catalog
        </span>
        <h1 class="text-3xl font-bold tracking-tight text-white leading-tight">
          {cleanCreator}
        </h1>
        <p class="text-xs text-text-secondary leading-relaxed max-w-xl">
          Explore and review the structured learning pathways published by channel "{cleanCreator}". Check Quality Scores, structures, and checklists.
        </p>
      </div>
    </section>

    <!-- Playlists list -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {filteredPlaylists.length === 0 ? (
        <div class="col-span-full py-16 text-center border border-dashed border-white/5 rounded-2xl">
          <h3 class="text-sm font-semibold text-white">No playlists found for creator "{cleanCreator}"</h3>
          <p class="text-xs text-text-muted mt-1 max-w-sm mx-auto">We couldn't locate any matching courses by this creator in the catalog right now.</p>
        </div>
      ) : (
        filteredPlaylists.map(playlist => (
          <div class="group glass-panel rounded-2xl overflow-hidden glass-panel-hover flex flex-col justify-between h-full relative">
            <div class="relative w-full aspect-video overflow-hidden border-b border-white/5 bg-zinc-950">
              <img src={playlist.thumbnail} alt={playlist.title} class="w-full h-full object-cover opacity-75 group-hover:scale-105 group-hover:opacity-90 transition-all duration-300" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
              
              <div class="absolute bottom-3 left-3 flex items-center gap-2 z-10">
                <span class="px-2.5 py-0.5 rounded-full bg-black/75 border border-white/5 text-[10px] font-mono text-white flex items-center gap-1">
                  {playlist.videoCount} videos
                </span>
                <span class="px-2.5 py-0.5 rounded-full bg-black/75 border border-white/5 text-[10px] font-mono text-white flex items-center gap-1">
                  {playlist.durationHours} hours
                </span>
              </div>
            </div>

            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <span class="text-[10px] font-mono uppercase tracking-wider text-zinc-500">{playlist.channel}</span>
                <h2 class="text-base font-bold tracking-tight text-white line-clamp-2 mt-1 leading-snug group-hover:text-accent transition-colors">
                  <a href={`/playlist/${playlist.slug}`}>{playlist.title}</a>
                </h2>
                <p class="text-xs text-zinc-400 line-clamp-2 leading-relaxed mt-2 mb-4">{playlist.description}</p>
              </div>

              <div class="border-t border-white/5 pt-4 flex items-center justify-between">
                <!-- Score Indicator -->
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full border border-accent/20 bg-accent/5 flex items-center justify-center font-mono font-bold text-xs text-white">
                    {playlist.score}
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[8px] uppercase tracking-wider text-accent font-semibold font-mono">Score</span>
                    <span class="text-[10px] text-zinc-500 leading-none">Quality</span>
                  </div>
                </div>

                <span class="text-[9px] uppercase px-2 py-0.5 rounded border border-white/10 text-text-secondary">
                  {playlist.difficulty}
                </span>
              </div>
            </div>

            <div class="px-6 pb-6 pt-2 flex gap-3">
              <a href={`/playlist/${playlist.slug}`} class="flex-1 py-2 px-4 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold flex items-center justify-center gap-1.5 transition-all shadow-lg text-center">
                Start Learning
              </a>
            </div>
          </div>
        ))
      )}
    </div>
  </div>
</Layout>
