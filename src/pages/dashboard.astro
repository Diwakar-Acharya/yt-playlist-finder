---
import Layout from '../layouts/Layout.astro';
import PlaylistCard from '../components/PlaylistCard.astro';
import { PLAYLISTS } from '../lib/db';
import { Layers, Bookmark, Flame, Play, Clock, Sparkles, Plus, BookOpen, CheckCircle } from '@lucide/astro';
---

<Layout 
  title="Student Dashboard | EasyTubeList"
  description="Manage your learning collections, track course completion progress, and resume saved playlists."
>
  <div class="space-y-12">
    <!-- Dashboard Header -->
    <section class="border-b border-white/5 pb-6">
      <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted">Student Workspace</span>
      <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Learning Dashboard</h1>
      <p class="text-xs text-text-secondary mt-1">Track your active courses, streak details, and saved collections.</p>
    </section>

    <!-- Progress Overview Panel (Grid) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Continue Learning (Progress) -->
      <div class="glass-panel rounded-2xl p-6 md:col-span-2 flex flex-col justify-between">
        <div>
          <h3 class="text-xs font-mono uppercase tracking-wider text-accent font-semibold mb-4 flex items-center gap-1.5">
            <Play class="w-3.5 h-3.5 fill-accent" /> Active Study Session
          </h3>
          
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <h4 class="text-sm font-bold text-white tracking-tight">Machine Learning Specialization Deep Dive</h4>
              <span class="text-[10px] font-mono text-text-muted mt-1 block" id="active-session-meta">DeepLearning.AI • 0 / 36 Videos Complete</span>
            </div>
            
            <div class="text-right shrink-0">
              <span class="text-xs font-mono font-semibold text-white" id="active-session-percent">0% Complete</span>
            </div>
          </div>

          <!-- Progress Bar -->
          <div class="w-full h-1.5 bg-zinc-900 rounded-full overflow-hidden mt-3 border border-white/5">
            <div class="h-full bg-accent rounded-full transition-all duration-300" id="active-session-bar" style="width: 0%"></div>
          </div>
        </div>

        <div class="mt-6 flex justify-end">
          <a 
            href="/playlist/andrew-ng-machine-learning" 
            class="px-4 py-1.5 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold hover:scale-95 transition-transform"
          >
            Resume Learning
          </a>
        </div>
      </div>

      <!-- Streaks Card -->
      <div class="glass-panel rounded-2xl p-6 flex flex-col justify-between relative overflow-hidden">
        <div class="absolute right-4 bottom-4 text-orange-500/5 -z-10 select-none">
          <Flame class="w-24 h-24" />
        </div>
        <div>
          <h3 class="text-xs font-mono uppercase tracking-wider text-orange-500 font-semibold mb-4 flex items-center gap-1.5">
            <Flame class="w-4 h-4 fill-orange-500/10" /> Streak Tracker
          </h3>
          
          <div class="space-y-1">
            <span class="text-3xl font-bold font-mono text-white" id="dash-streak-count">0</span>
            <span class="text-[10px] font-mono text-text-muted block">Consecutive learning days</span>
          </div>
        </div>

        <p class="text-[10px] text-text-secondary leading-normal mt-4">
          Activate Study Mode on any playlist page to check off today's study goal and maintain your streak.
        </p>
      </div>

    </div>

    <!-- Saved Collections (Bookmarks) -->
    <section class="space-y-6">
      <div class="flex items-center justify-between border-b border-white/5 pb-3">
        <h2 class="text-lg font-bold tracking-tight text-white flex items-center gap-2">
          <Bookmark class="w-4 h-4 text-accent" /> Saved Playlists
        </h2>
        <span class="text-xs text-text-muted font-mono" id="saved-count-label">0 Playlists</span>
      </div>

      <!-- Dynamic Saved Playlists Grid -->
      <div id="saved-playlists-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Rendered client-side based on localStorage bookmarks -->
      </div>

      <!-- Empty State -->
      <div id="saved-empty-state" class="hidden flex-col items-center justify-center py-16 text-center border border-dashed border-white/5 rounded-2xl">
        <div class="w-12 h-12 rounded-full bg-zinc-950 border border-white/5 flex items-center justify-center text-text-muted mb-4">
          <Bookmark class="w-5 h-5" />
        </div>
        <h3 class="text-sm font-semibold text-white">No saved playlists</h3>
        <p class="text-xs text-text-muted max-w-sm mt-1">Explore our playlist rank listings and bookmark courses to track them on your dashboard.</p>
        <a href="/" class="mt-4 px-4 py-1.5 rounded-xl bg-accent text-white text-xs font-semibold hover:scale-95 transition-transform">
          Explore Playlists
        </a>
      </div>
    </section>

    <!-- Custom collections category cards -->
    <section class="space-y-6">
      <h2 class="text-lg font-bold tracking-tight text-white">Learning Collections</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        <div class="p-5 rounded-2xl border border-white/5 bg-zinc-950/40 hover:border-white/10 transition-all flex flex-col justify-between cursor-pointer group">
          <span class="text-xs font-bold text-white group-hover:text-accent">Machine Learning (ML)</span>
          <span class="text-[9px] font-mono text-text-muted mt-4 block">1 saved track</span>
        </div>
        <div class="p-5 rounded-2xl border border-white/5 bg-zinc-950/40 hover:border-white/10 transition-all flex flex-col justify-between cursor-pointer group">
          <span class="text-xs font-bold text-white group-hover:text-accent">College Placement Prep</span>
          <span class="text-[9px] font-mono text-text-muted mt-4 block">2 saved tracks</span>
        </div>
        <div class="p-5 rounded-2xl border border-white/5 bg-zinc-950/40 hover:border-white/10 transition-all flex flex-col justify-between cursor-pointer group">
          <span class="text-xs font-bold text-white group-hover:text-accent">Exam Preparation</span>
          <span class="text-[9px] font-mono text-text-muted mt-4 block">0 saved tracks</span>
        </div>
      </div>
    </section>

  </div>
</Layout>

<script is:inline define:vars={{ PLAYLISTS }}>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('saved-playlists-grid');
    const emptyState = document.getElementById('saved-empty-state');
    const countLabel = document.getElementById('saved-count-label');
    const streakCount = document.getElementById('dash-streak-count');

    // Sync streak
    if (streakCount) {
      streakCount.textContent = (localStorage.getItem('streak') || '0').toString();
    }

    // Sync active study session progress
    function syncActiveSession() {
      const activeMeta = document.getElementById('active-session-meta');
      const activePercent = document.getElementById('active-session-percent');
      const activeBar = document.getElementById('active-session-bar');
      const activeSlug = 'andrew-ng-machine-learning';
      const activePlaylist = PLAYLISTS.find(p => p.slug === activeSlug);

      if (activePlaylist) {
        let completedList = [];
        try {
          const completed = JSON.parse(localStorage.getItem('completedVideos') || '{}');
          completedList = completed[activeSlug] || [];
        } catch {
          completedList = [];
        }
        
        const completedCount = completedList.length;
        const totalCount = activePlaylist.videoCount;
        const percent = totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0;
        
        // Sum up completed duration (estimate 15 mins per video)
        const completedMins = completedCount * 15;
        
        if (activeMeta) activeMeta.textContent = `${activePlaylist.channel} • ${completedCount} / ${totalCount} Videos Complete`;
        if (activePercent) activePercent.textContent = `${percent}% Complete`;
        if (activeBar) activeBar.style.width = `${percent}%`;
      }
    }

    function renderSaved() {
      if (!grid || !emptyState) return;

      let savedSlugs = [];
      try {
        savedSlugs = JSON.parse(localStorage.getItem('savedPlaylists') || '[]');
      } catch {
        savedSlugs = [];
      }

      // Filter global db object based on user saved slugs
      const savedPlaylists = PLAYLISTS.filter(p => savedSlugs.includes(p.slug));

      if (countLabel) {
        countLabel.textContent = `${savedPlaylists.length} ${savedPlaylists.length === 1 ? 'Playlist' : 'Playlists'}`;
      }

      if (savedPlaylists.length === 0) {
        grid.innerHTML = '';
        emptyState.classList.remove('hidden');
        emptyState.classList.add('flex');
        return;
      }

      emptyState.classList.add('hidden');
      emptyState.classList.remove('flex');

      // Create card list
      grid.innerHTML = savedPlaylists.map(playlist => {
        const getDifficultyBadge = (diff) => {
          if (diff === 'Beginner') return 'border-emerald-500/20 text-emerald-400 bg-emerald-950/10';
          if (diff === 'Intermediate') return 'border-yellow-500/20 text-yellow-400 bg-yellow-950/10';
          return 'border-red-500/20 text-red-400 bg-red-950/10';
        };

        return `
          <div class="group glass-panel rounded-2xl overflow-hidden glass-panel-hover flex flex-col justify-between h-full relative">
            <div class="relative w-full aspect-video overflow-hidden border-b border-white/5 bg-zinc-950">
              <img src="${playlist.thumbnail}" alt="${playlist.title}" class="w-full h-full object-cover opacity-75 group-hover:scale-105 group-hover:opacity-90 transition-all duration-300" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
              
              <div class="absolute bottom-3 left-3 flex items-center gap-2 z-10">
                <span class="px-2.5 py-0.5 rounded-full bg-black/75 border border-white/5 text-[10px] font-mono text-white flex items-center gap-1">
                  ${playlist.videoCount} videos
                </span>
                <span class="px-2.5 py-0.5 rounded-full bg-black/75 border border-white/5 text-[10px] font-mono text-white flex items-center gap-1">
                  ${playlist.durationHours} hours
                </span>
              </div>
            </div>

            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <span class="text-[10px] font-mono uppercase tracking-wider text-zinc-500">${playlist.channel}</span>
                <h3 class="text-base font-bold tracking-tight text-white line-clamp-2 mt-1 leading-snug group-hover:text-accent transition-colors">${playlist.title}</h3>
                <p class="text-xs text-zinc-400 line-clamp-2 leading-relaxed mt-2 mb-4">${playlist.description}</p>
              </div>

              <div class="border-t border-white/5 pt-4 flex items-center justify-between">
                <!-- Simple Score Indicator -->
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full border border-accent/20 bg-accent/5 flex items-center justify-center font-mono font-bold text-xs text-white">
                    ${playlist.score}
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[8px] uppercase tracking-wider text-accent font-semibold font-mono">Score</span>
                    <span class="text-[10px] text-zinc-500 leading-none">Quality</span>
                  </div>
                </div>

                <span class="text-[9px] uppercase px-2 py-0.5 rounded border ${getDifficultyBadge(playlist.difficulty)}">
                  ${playlist.difficulty}
                </span>
              </div>
            </div>

            <div class="px-6 pb-6 pt-2 flex gap-3">
              <a href="/playlist/${playlist.slug}" class="flex-1 py-2 px-4 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold flex items-center justify-center gap-1.5 transition-all shadow-lg">
                Start Learning
              </a>
            </div>
          </div>
        `;
      }).join('');
    }

    renderSaved();
    syncActiveSession();

    // Listen for updates from other components
    window.addEventListener('savedPlaylistsUpdated', renderSaved);
    window.addEventListener('studyMetricsUpdated', syncActiveSession);
  });
</script>
