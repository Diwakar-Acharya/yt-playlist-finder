---
import Layout from '../layouts/Layout.astro';
import PlaylistCard from '../components/PlaylistCard.astro';
import { searchPlaylists } from '../lib/api';
import { getCloudflareEnv } from '../lib/youtube';
import { 
  Search, 
  ArrowRight, 
  Flame, 
  CheckCircle, 
  SlidersHorizontal, 
  Sparkles, 
  ChevronDown, 
  GraduationCap,
  Compass,
  Cpu
} from '@lucide/astro';

import { 
  validateQuery, 
  validateDifficulty, 
  validateDuration, 
  validateSort 
} from '../lib/validation';

// Parse query params in Astro frontmatter (Server-Side)
const url = new URL(Astro.request.url);
const rawQuery = url.searchParams.get('q') || '';
const rawDifficulty = url.searchParams.get('difficulty') || '';
const rawDuration = url.searchParams.get('duration') || '';
const rawSort = url.searchParams.get('sort') || 'best';

const query = validateQuery(rawQuery);
const difficulty = validateDifficulty(rawDifficulty) || '';
const duration = validateDuration(rawDuration) || '';
const sort = validateSort(rawSort);

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

// Fetch results on server (No client-side fetching)
const playlists = query 
  ? await searchPlaylists(query, { difficulty, duration }, sort, apiKey, env)
  : [];

// Fetch editor picks resolved to YouTube IDs
const editorPicks = await searchPlaylists('', {}, 'best', apiKey, env);

const trendingKeywords = ['Machine Learning', 'DSA', 'Python', 'Web Dev', 'Docker'];

const categories = [
  { name: 'Machine Learning', count: 3, slug: 'Machine Learning' },
  { name: 'Data Structures & Algorithms', count: 2, slug: 'DSA' },
  { name: 'Python Development', count: 2, slug: 'Python' },
  { name: 'Academic Science', count: 1, slug: 'Organic Chemistry' }
];

const faqs = [
  {
    q: "How to find the best YouTube playlist for any topic?",
    a: "To find the best YouTube playlist for any topic, enter your search query at the top of the page. Our system calls the official YouTube Data API v3 and calculates structured scoring algorithms, helping you locate high-quality courses instantly."
  },
  {
    q: "What is YouTube Playlist Finder?",
    a: "YouTube Playlist Finder is an educational catalog designed to resolve tutorial decision fatigue by parsing and scoring complete playlists from authorized YouTube channels."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<Layout 
  title="youtubeplaylistfinder | Find the Best YouTube Playlists for Anything"
  description="Discover the absolute best study and educational YouTube playlists. We mathematically rank, review, and score playlists to help you find structured learning paths instantly."
  schema={faqSchema}
>
  
  <!-- Hero Section -->
  <section class="text-center py-16 md:py-24 relative overflow-hidden flex flex-col items-center">
    <div class="absolute -top-40 -z-10 w-[600px] h-[300px] rounded-full bg-accent/10 blur-[120px]"></div>
    
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-accent/20 bg-accent/5 text-[10px] font-mono text-accent mb-6">
      <Sparkles class="w-3 h-3 text-accent animate-pulse" /> Streamlining Self-Education
    </div>
    
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-tight max-w-4xl accent-gradient-text">
      Find the Best YouTube Playlist for Anything.
    </h1>
    
    <p class="text-sm md:text-base text-text-secondary mt-6 max-w-2xl leading-relaxed">
      Stop wasting hours comparing disjointed videos. Search once, review transparent quality scores, and jump straight into guided syllabus sequences.
    </p>

    <!-- Search input form (Standard GET Submission) -->
    <div class="w-full max-w-2xl mt-10 relative z-20">
      <form method="GET" action="/" class="relative">
        <Search class="w-5 h-5 text-text-muted absolute left-4 top-1/2 -translate-y-1/2" />
        <input 
          type="text" 
          name="q"
          value={query}
          required
          placeholder="What do you want to learn today?" 
          class="w-full h-14 pl-12 pr-28 rounded-2xl border border-white/5 bg-zinc-950/60 backdrop-blur-md text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent/60 focus:ring-1 focus:ring-accent/40 shadow-2xl transition-all"
        />
        {difficulty && <input type="hidden" name="difficulty" value={difficulty} />}
        {duration && <input type="hidden" name="duration" value={duration} />}
        {sort && <input type="hidden" name="sort" value={sort} />}
        <button 
          type="submit" 
          class="absolute right-2 top-2 h-10 px-5 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold flex items-center gap-1 hover:scale-95 active:scale-95 transition-all cursor-pointer"
        >
          Search <ArrowRight class="w-3.5 h-3.5" />
        </button>
      </form>

      <!-- Trending keywords row -->
      <div class="flex flex-wrap items-center justify-center gap-2 mt-4 text-xs">
        <span class="text-text-muted font-mono text-[10px]">Trending searches:</span>
        {trendingKeywords.map(k => (
          <a 
            href={`/?q=${encodeURIComponent(k)}`}
            class="px-2.5 py-0.5 rounded-full border border-white/5 bg-zinc-900/40 text-text-secondary hover:text-white hover:border-white/10 transition-all font-mono text-[10px]"
          >
            {k}
          </a>
        ))}
      </div>
    </div>
  </section>

  {query ? (
    <section id="search-results-section" class="min-h-[400px] border-t border-white/5 pt-12 mt-8">
      <div class="flex flex-col md:flex-row gap-8">
        
        <div class="w-full md:w-64 shrink-0 space-y-6">
          <div class="flex items-center justify-between border-b border-white/5 pb-3">
            <h3 class="text-sm font-bold tracking-tight text-white flex items-center gap-1.5">
              <SlidersHorizontal class="w-4 h-4 text-accent" /> Search Filters
            </h3>
            <a href={`/?q=${encodeURIComponent(query)}`} class="text-[10px] text-text-muted hover:text-white font-mono">Reset All</a>
          </div>

          <form method="GET" action="/" class="space-y-6">
            <input type="hidden" name="q" value={query} />
            
            <!-- Difficulty filter -->
            <div class="space-y-2">
              <label class="text-[10px] uppercase font-mono tracking-wider text-text-muted block">Difficulty</label>
              <div class="space-y-1.5">
                {['Beginner', 'Intermediate', 'Advanced'].map(lvl => (
                  <label class="flex items-center gap-2 text-xs text-text-secondary hover:text-white cursor-pointer select-none">
                    <input 
                      type="radio" 
                      name="difficulty" 
                      value={lvl}
                      checked={difficulty === lvl}
                      onchange="this.form.submit()"
                      class="rounded-full border-white/10 bg-zinc-900 text-accent focus:ring-accent"
                    />
                    <span>{lvl}</span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Duration filter -->
            <div class="space-y-2">
              <label class="text-[10px] uppercase font-mono tracking-wider text-text-muted block">Duration</label>
              <div class="space-y-1.5">
                <label class="flex items-center gap-2 text-xs text-text-secondary hover:text-white cursor-pointer">
                  <input 
                    type="radio" 
                    name="duration" 
                    value="short" 
                    checked={duration === 'short'}
                    onchange="this.form.submit()"
                    class="rounded-full border-white/10 bg-zinc-900 text-accent focus:ring-accent"
                  />
                  <span>Short course (&lt;40h)</span>
                </label>
                <label class="flex items-center gap-2 text-xs text-text-secondary hover:text-white cursor-pointer">
                  <input 
                    type="radio" 
                    name="duration" 
                    value="medium" 
                    checked={duration === 'medium'}
                    onchange="this.form.submit()"
                    class="rounded-full border-white/10 bg-zinc-900 text-accent focus:ring-accent"
                  />
                  <span>Mid course (40-65h)</span>
                </label>
                <label class="flex items-center gap-2 text-xs text-text-secondary hover:text-white cursor-pointer">
                  <input 
                    type="radio" 
                    name="duration" 
                    value="long" 
                    checked={duration === 'long'}
                    onchange="this.form.submit()"
                    class="rounded-full border-white/10 bg-zinc-900 text-accent focus:ring-accent"
                  />
                  <span>Comprehensive (&gt;65h)</span>
                </label>
              </div>
            </div>

            <!-- Sort filter -->
            <div class="space-y-2 pt-2 border-t border-white/5">
              <label for="sort-select" class="text-[10px] uppercase font-mono tracking-wider text-text-muted block">Sort by</label>
              <select 
                id="sort-select"
                name="sort" 
                onchange="this.form.submit()"
                class="w-full bg-zinc-900 border border-white/5 text-xs text-white rounded-xl py-2 px-3 focus:outline-none focus:border-accent"
              >
                <option value="best" selected={sort === 'best'}>Best Score</option>
                <option value="fastest" selected={sort === 'fastest'}>Fastest (Shortest)</option>
                <option value="complete" selected={sort === 'complete'}>Most Complete</option>
              </select>
            </div>
          </form>
        </div>

        <div class="flex-1 space-y-6">
          {!apiKey && (
            <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-2xl flex items-start gap-3">
              <span class="text-amber-500 text-sm mt-0.5">⚠️</span>
              <div class="space-y-0.5">
                <h4 class="text-xs font-bold text-white">YouTube API Key Offline Mode</h4>
                <p class="text-[11px] text-text-muted leading-relaxed">
                  Live YouTube search requires a YouTube Data API v3 key. To search all of YouTube, configure the <code>YOUTUBE_API_KEY</code> environment variable. Displaying mock/static courses database.
                </p>
              </div>
            </div>
          )}

          <div class="flex items-center justify-between text-xs text-text-muted font-mono border-b border-white/5 pb-3">
            {playlists.length > 0 && playlists[0].isFallback ? (
              <span>No direct results found for "{query}". Showing popular courses:</span>
            ) : (
              <span>Found {playlists.length} {playlists.length === 1 ? 'playlist' : 'playlists'} for "{query}"</span>
            )}
            <span>Ranked by quality</span>
          </div>

          {playlists.length === 0 ? (
            <div class="flex flex-col items-center justify-center py-20 text-center border border-dashed border-white/5 rounded-2xl">
              <h4 class="text-sm font-semibold text-white">No playlists found</h4>
              <p class="text-xs text-text-muted max-w-sm mt-1">We couldn't find any scored playlists. The engine automatically crawls matching YouTube tracks when you request them.</p>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {playlists.map(p => <PlaylistCard playlist={p} />)}
            </div>
          )}
        </div>

      </div>
    </section>
  ) : (
    <div class="space-y-24 mt-12">
      
      <!-- Editor Picks static gallery -->
      <section class="max-w-5xl mx-auto py-8">
        <div class="text-center mb-8">
          <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted">Top Rated Today</span>
          <h2 class="text-2xl font-bold tracking-tight text-white mt-1">Recommended Tracks</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {editorPicks.slice(0, 3).map(p => (
            <PlaylistCard playlist={p} />
          ))}
        </div>
      </section>

      <!-- How It Works Section -->
      <section class="border-t border-white/5 pt-20">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white accent-gradient-text">How It Works.</h2>
          <p class="text-xs text-text-secondary mt-3">We skip the noise and analyze structure, reviews, and recency mathematically.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="glass-panel rounded-2xl p-6 relative">
            <span class="absolute top-4 right-4 text-4xl font-extrabold font-mono text-white/5 select-none">01</span>
            <div class="w-8 h-8 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent mb-4">
              <Search class="w-4 h-4" />
            </div>
            <h3 class="text-sm font-bold text-white uppercase tracking-wider font-mono">1. Query Anything</h3>
            <p class="text-xs text-text-secondary mt-2 leading-relaxed">Enter a skill, topic, or field. Our database dynamically searches YouTube APIs to fetch matched tracks.</p>
          </div>

          <div class="glass-panel rounded-2xl p-6 relative">
            <span class="absolute top-4 right-4 text-4xl font-extrabold font-mono text-white/5 select-none">02</span>
            <div class="w-8 h-8 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent mb-4">
              <Cpu class="w-4 h-4" />
            </div>
            <h3 class="text-sm font-bold text-white uppercase tracking-wider font-mono">2. Calculate Quality Score</h3>
            <p class="text-xs text-text-secondary mt-2 leading-relaxed">Every playlist undergoes strict multi-factor evaluation (Structure, Reviews, fresh checks) yielding transparent scores.</p>
          </div>

          <div class="glass-panel rounded-2xl p-6 relative">
            <span class="absolute top-4 right-4 text-4xl font-extrabold font-mono text-white/5 select-none">03</span>
            <div class="w-8 h-8 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent mb-4">
              <GraduationCap class="w-4 h-4" />
            </div>
            <h3 class="text-sm font-bold text-white uppercase tracking-wider font-mono">3. Distraction-Free Study</h3>
            <p class="text-xs text-text-secondary mt-2 leading-relaxed">Export playlists, click "Study Mode" to block comments, and monitor your daily streak details automatically.</p>
          </div>
        </div>
      </section>

      <!-- Categories Grid Section -->
      <section class="border-t border-white/5 pt-20">
        <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-10">
          <div>
            <h2 class="text-2xl font-bold tracking-tight text-white">Popular Subject Tracts</h2>
            <p class="text-xs text-text-muted mt-1">Jump directly into scored listings for high-demand topics.</p>
          </div>
          <Compass class="w-5 h-5 text-text-muted" />
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {categories.map(c => (
            <a 
              href={`/?q=${encodeURIComponent(c.slug)}`}
              class="group p-5 rounded-2xl border border-white/5 bg-zinc-950/40 hover:bg-zinc-900/60 hover:border-white/10 transition-all flex flex-col justify-between text-left"
            >
              <span class="text-xs font-semibold text-white group-hover:text-accent transition-colors">{c.name}</span>
              <span class="text-[10px] font-mono text-text-muted mt-4 block">{c.count} Tracks Scored</span>
            </a>
          ))}
        </div>
      </section>

      <!-- FAQ Accordion -->
      <section class="border-t border-white/5 pt-20 max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-2xl font-bold tracking-tight text-white">Frequently Asked Questions</h2>
          <p class="text-xs text-text-muted mt-1">Get instant answers to common questions about finding, saving, and ranking YouTube study playlists.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
          {faqs.map(faq => (
            <details class="group border border-white/5 bg-zinc-950/40 rounded-2xl p-4 cursor-pointer [&_summary::-webkit-details-marker]:hidden h-fit transition-colors hover:border-white/10">
              <summary class="flex justify-between items-center text-xs font-semibold text-white font-mono select-none">
                <span>{faq.q}</span>
                <span class="transition-transform group-open:rotate-180 text-text-muted group-hover:text-white shrink-0 ml-4">
                  <ChevronDown class="w-4 h-4" />
                </span>
              </summary>
              <p class="text-xs text-text-secondary leading-relaxed mt-3 border-t border-white/5 pt-3 pl-1">
                {faq.a}
              </p>
            </details>
          ))}
        </div>
      </section>
    </div>
  )}

</Layout>
