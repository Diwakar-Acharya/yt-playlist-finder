---
import Layout from '../layouts/Layout.astro';
import PlaylistCard from '../components/PlaylistCard.astro';
import { searchPlaylists } from '../lib/api';
import { getCloudflareEnv } from '../lib/youtube';
import { Sparkles } from '@lucide/astro';

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

// Fetch and validate playlists on server
const playlists = await searchPlaylists('', {}, 'best', apiKey, env);

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "New Playlists", "item": "https://youtubeplaylistfinder.com/new-playlists" }
  ]
};
---

<Layout 
  title="New Scored YouTube Playlists - Fresh study guides | youtubeplaylistfinder"
  description="Browse recently added study and tutorial YouTube playlists. Access scored guides mapping the latest programming and academic courses."
  canonical="https://youtubeplaylistfinder.com/new-playlists"
  schema={breadcrumbs}
>
  <div class="space-y-12">
    <!-- Header -->
    <section class="border-b border-white/5 pb-6">
      <div class="flex items-center gap-2">
        <Sparkles class="w-5 h-5 text-accent" />
        <div>
          <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted font-semibold">Fresh Additions</span>
          <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Recently Added Tracks</h1>
        </div>
      </div>
      <p class="text-xs text-text-secondary mt-2">Recently scored educational catalogs updating you with the latest tutorial syllabus releases.</p>
    </section>

    <!-- Listings Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.map(playlist => (
        <PlaylistCard playlist={playlist} />
      ))}
    </div>
  </div>
</Layout>
