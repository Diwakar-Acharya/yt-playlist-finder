---
import Layout from '../../layouts/Layout.astro';
import ScoreIndicator from '../../components/ScoreIndicator.astro';
import TopicGraph from '../../components/TopicGraph.astro';
import { getPlaylistBySlug, getCustomPathwayRoadmap } from '../../lib/api';
import { 
  Play, 
  Bookmark, 
  Clock, 
  BookOpen, 
  Award,
  ChevronRight,
  ExternalLink,
  Sparkles,
  Star,
  Eye,
  ChevronLeft,
  CheckSquare,
  ArrowRight,
  HelpCircle
} from '@lucide/astro';

// Serves page dynamically in SSR mode
const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/404');
}

const playlist = await getPlaylistBySlug(slug);

if (!playlist) {
  return Astro.redirect('/404');
}

// Fetch dynamically generated custom learning pathway
const pathway = getCustomPathwayRoadmap(playlist);

// Fetch alternatives
const alternatives = (await Promise.all(
  playlist.alternatives.map(altSlug => getPlaylistBySlug(altSlug))
)).filter(Boolean);

const getDurationMins = (durationStr: string): number => {
  const parts = durationStr.split(':').map(Number);
  if (parts.length === 3) {
    return parts[0] * 60 + parts[1];
  } else if (parts.length === 2) {
    return parts[0];
  }
  return 15;
};
---

<Layout 
  title={`${playlist.title} | Quality Rank ${playlist.score}/100`}
  description={playlist.description}
>
  <div id="playlist-page-container">
    <!-- Back to search link -->
    <div class="mb-6 study-hide transition-opacity duration-300">
      <a href="/" class="inline-flex items-center gap-1 text-xs text-text-secondary hover:text-white transition-colors">
        <ChevronLeft class="w-4 h-4" /> Back to listings
      </a>
    </div>

    <!-- Header Banner block -->
    <section class="glass-panel rounded-3xl p-6 md:p-10 mb-8 relative overflow-hidden study-hide transition-opacity duration-300">
      <div class="absolute right-0 top-0 bottom-0 w-1/3 opacity-15 hidden md:block">
        <img src={playlist.thumbnail} alt="" class="w-full h-full object-cover blur-sm" />
        <div class="absolute inset-0 bg-gradient-to-r from-black to-transparent"></div>
      </div>
      
      <div class="relative z-10 max-w-3xl space-y-4">
        <!-- Badge -->
        <span class="px-2.5 py-0.5 rounded-full border border-white/5 bg-zinc-900 text-[10px] font-mono text-zinc-400">
          Ranked Course
        </span>
        
        <h1 class="text-2xl md:text-4xl font-bold tracking-tight text-white leading-tight">
          {playlist.title}
        </h1>

        <p class="text-xs md:text-sm text-text-secondary leading-relaxed max-w-2xl">
          {playlist.description}
        </p>

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-4 text-xs font-mono text-text-muted pt-2">
          <span>Channel: <strong class="text-white">{playlist.channel}</strong> ({playlist.channelSubscriberCount})</span>
          <span>•</span>
          <span>{playlist.videoCount} Videos</span>
          <span>•</span>
          <span>{playlist.durationHours} Hours</span>
          <span>•</span>
          <span class="text-emerald-400">{playlist.freshness}</span>
        </div>
      </div>
    </section>

    <!-- Metrics Breakdown Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      
      <!-- Score indicator -->
      <div class="md:col-span-2 space-y-6">
        <div class="glass-panel rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 relative overflow-hidden">
          <div class="absolute right-4 bottom-4 text-accent/5 -z-10 select-none">
            <Award class="w-32 h-32" />
          </div>
          <div>
            <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted block">Quality Score</span>
            <h2 class="text-3xl font-extrabold text-white tracking-tighter mt-1 font-mono">{playlist.score}<span class="text-lg text-zinc-500 font-normal">/100</span></h2>
            <p class="text-[10px] text-text-muted mt-2 max-w-sm">Calculated from multi-factor ranking algorithms. Complete syllabus videos to raise your profile metrics.</p>
          </div>
          <div class="shrink-0">
            <ScoreIndicator score={playlist.score} breakdown={playlist.scoreBreakdown} showBreakdown={true} size="md" />
          </div>
        </div>
      </div>

      <!-- Action Panel with checklist status -->
      <div class="glass-panel rounded-2xl p-6 flex flex-col justify-between study-hide transition-opacity duration-300">
        <div class="space-y-4">
          <h3 class="text-xs font-mono uppercase tracking-wider text-white">Your Progress</h3>
          <div class="space-y-3 font-mono text-xs text-text-secondary">
            <div class="flex justify-between">
              <span>Completed Modules</span>
              <span class="text-white font-semibold" id="modules-completed-label">0 / {playlist.videoCount}</span>
            </div>
            <div class="flex justify-between">
              <span>Study Completion</span>
              <span class="text-white font-semibold" id="study-percent-label">0%</span>
            </div>
            <div class="flex justify-between">
              <span>Time Completed</span>
              <span class="text-white font-semibold" id="time-completed-label">0 mins</span>
            </div>
          </div>
          
          <!-- Progress meter line -->
          <div class="w-full h-1.5 bg-zinc-900 rounded-full overflow-hidden border border-white/5 mt-2">
            <div class="h-full bg-accent rounded-full transition-all duration-300" id="progress-meter" style="width: 0%"></div>
          </div>
        </div>

        <div class="space-y-3 mt-8">
          <a 
            href={`https://www.youtube.com/playlist?list=${playlist.slug}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-2.5 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold flex items-center justify-center gap-1.5 transition-all shadow-lg text-center"
          >
            <Play class="w-3.5 h-3.5 fill-black" /> Open in YouTube <ExternalLink class="w-3 h-3" />
          </a>

          <button 
            id="study-mode-toggle"
            class="w-full py-2.5 rounded-xl border border-accent/20 bg-accent/5 hover:bg-accent/15 text-accent text-xs font-semibold flex items-center justify-center gap-1.5 transition-all cursor-pointer"
          >
            <Eye class="w-3.5 h-3.5" /> Start Study Mode
          </button>
        </div>
      </div>

    </div>

    <!-- Active Study Mode Banner -->
    <div id="study-active-banner" class="hidden glass-panel border border-accent/30 rounded-2xl p-4 items-center justify-between gap-4 mb-8 bg-accent/5 animate-pulse">
      <div class="flex items-center gap-2">
        <Sparkles class="w-4 h-4 text-accent" />
        <span class="text-xs font-mono text-white">Study Mode Active — Distractions Hidden</span>
      </div>
      <button 
        id="study-mode-exit"
        class="py-1.5 px-3 rounded-lg bg-zinc-900 border border-white/10 hover:bg-white hover:text-black text-xs font-semibold transition-all cursor-pointer"
      >
        Exit Study Mode
      </button>
    </div>

    <!-- Details/Video/Tabs Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Video checklist modules timeline -->
      <div class="lg:col-span-2 space-y-8">
        
        <!-- Video list sequence block -->
        <div class="glass-panel rounded-2xl p-6 md:p-8" id="video-sequence-container">
          <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-6">
            <div>
              <h3 class="text-sm font-mono uppercase tracking-wider text-white">Course Modules Sequence</h3>
              <p class="text-xs text-text-muted mt-0.5">Check off completed lessons to calculate exact profile hours.</p>
            </div>
            <CheckSquare class="w-4 h-4 text-text-muted" />
          </div>

          <div class="space-y-3">
            {playlist.videos.map((vid, idx) => (
              <div 
                class="video-row flex items-center justify-between gap-4 p-3 rounded-xl border border-white/5 bg-zinc-950/40 hover:bg-zinc-900/60 hover:border-white/10 transition-colors group cursor-pointer"
                data-video-id={vid.id}
                data-duration={getDurationMins(vid.duration)} 
              >
                <div class="flex items-center gap-4 flex-1">
                  <!-- Checkbox input -->
                  <input 
                    type="checkbox" 
                    class="video-checkbox w-4.5 h-4.5 rounded border-white/10 bg-zinc-900 text-accent focus:ring-accent cursor-pointer"
                    data-video-id={vid.id}
                    data-duration={getDurationMins(vid.duration)} 
                  />
                  
                  <span class="text-[10px] font-mono text-text-secondary group-hover:text-accent transition-colors">
                    {idx + 1}
                  </span>
                  
                  <div>
                    <h4 class="text-xs font-bold text-white group-hover:text-accent transition-colors line-clamp-1">
                      {vid.title}
                    </h4>
                    <span class="text-[10px] text-text-muted font-mono">{vid.duration} mins</span>
                  </div>
                </div>

                <a 
                  href={`https://www.youtube.com/watch?v=${vid.id}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-1.5 rounded-lg border border-white/5 bg-zinc-950 hover:border-accent hover:text-accent transition-colors text-text-secondary"
                >
                  <ExternalLink class="w-3.5 h-3.5" />
                </a>
              </div>
            ))}
          </div>
        </div>

        <!-- Dynamic Syllabus coverage graph -->
        <div class="study-hide transition-opacity duration-300">
          <TopicGraph topics={playlist.topics} missingTopics={playlist.missingTopics} />
        </div>

      </div>

      <!-- Sidebar Column (Playlists-Specific Roadmap and Alternatives) -->
      <div class="space-y-8">
        
        <!-- CUSTOM LEARNING ROADMAP (Specific to this playlist) -->
        <div class="glass-panel rounded-2xl p-6 study-hide transition-opacity duration-300">
          <h3 class="text-xs font-mono uppercase tracking-wider text-white mb-4">Syllabus Learning Path</h3>
          
          <div class="relative pl-6 border-l border-white/5 space-y-6">
            
            <!-- Prerequisite step -->
            {pathway.prerequisite && (
              <div class="relative">
                <span class="absolute -left-[30px] top-1.5 w-3 h-3 rounded-full border-2 border-black bg-zinc-700 flex items-center justify-center"></span>
                <div class="flex flex-col gap-0.5">
                  <span class="text-[9px] font-mono uppercase tracking-wider text-text-muted">1. Prerequisite Foundation</span>
                  <h4 class="text-xs font-bold text-white leading-tight">{pathway.prerequisite.title}</h4>
                  <p class="text-[10px] text-text-secondary leading-snug">{pathway.prerequisite.description}</p>
                  <a 
                    href={`/playlist/${pathway.prerequisite.slug}`}
                    class="text-[9px] text-accent hover:underline font-mono mt-1 flex items-center gap-0.5"
                  >
                    View course →
                  </a>
                </div>
              </div>
            )}

            <!-- Current step -->
            <div class="relative">
              <span class="absolute -left-[30px] top-1.5 w-3 h-3 rounded-full border-2 border-black bg-accent flex items-center justify-center shadow-[0_0_5px_#6d5ef7]"></span>
              <div class="flex flex-col gap-0.5">
                <span class="text-[9px] font-mono uppercase tracking-wider text-accent font-semibold">
                  {pathway.prerequisite ? '2. Current Study Track' : '1. Current Study Track'}
                </span>
                <h4 class="text-xs font-bold text-white leading-tight">{pathway.current.title}</h4>
                <p class="text-[10px] text-text-secondary leading-snug">You are currently examining this syllabus details.</p>
              </div>
            </div>

            <!-- Next Step step -->
            {pathway.nextStep && (
              <div class="relative">
                <span class="absolute -left-[30px] top-1.5 w-3 h-3 rounded-full border-2 border-black bg-zinc-800 flex items-center justify-center"></span>
                <div class="flex flex-col gap-0.5">
                  <span class="text-[9px] font-mono uppercase tracking-wider text-text-muted">
                    {pathway.prerequisite ? '3. Logical Next Step' : '2. Logical Next Step'}
                  </span>
                  <h4 class="text-xs font-bold text-white leading-tight">{pathway.nextStep.title}</h4>
                  <p class="text-[10px] text-text-secondary leading-snug">{pathway.nextStep.description}</p>
                  <a 
                    href={`/playlist/${pathway.nextStep.slug}`}
                    class="text-[9px] text-accent hover:underline font-mono mt-1 flex items-center gap-0.5"
                  >
                    Examine roadmap next →
                  </a>
                </div>
              </div>
            )}

          </div>
        </div>

        <!-- Alternatives list -->
        {alternatives.length > 0 && (
          <div class="glass-panel rounded-2xl p-6 study-hide transition-opacity duration-300">
            <h3 class="text-xs font-mono uppercase tracking-wider text-white mb-4 font-semibold">Alternatives</h3>
            <div class="space-y-4">
              {alternatives.map(alt => (
                <a 
                  href={`/playlist/${alt.slug}`}
                  class="flex gap-3 p-2.5 rounded-xl border border-white/5 bg-zinc-950/20 hover:bg-zinc-900/40 transition-colors group"
                >
                  <img src={alt.thumbnail} alt="" class="w-16 aspect-video object-cover rounded border border-white/5" />
                  <div class="flex flex-col justify-between py-0.5">
                    <h4 class="text-xs font-bold text-white group-hover:text-accent line-clamp-1 transition-colors">{alt.title}</h4>
                    <span class="text-[9px] font-mono text-zinc-500">Score: <strong class="text-white">{alt.score}/100</strong></span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Review panel -->
        <div class="glass-panel rounded-2xl p-6 study-hide transition-opacity duration-300">
          <h3 class="text-xs font-mono uppercase tracking-wider text-white mb-4">Student Feedback</h3>
          <div class="space-y-4">
            {playlist.reviews.map(rev => (
              <div class="p-3.5 rounded-xl border border-white/5 bg-zinc-950/40 space-y-2">
                <div class="flex items-center justify-between text-[10px] font-mono">
                  <div>
                    <span class="font-bold text-white">{rev.name}</span>
                    <span class="text-text-muted block text-[9px]">{rev.role}</span>
                  </div>
                  <span class="text-yellow-500 flex items-center gap-0.5 font-bold">
                    <Star class="w-3 h-3 fill-yellow-500" /> {rev.rating}
                  </span>
                </div>
                <p class="text-xs text-text-secondary leading-relaxed">
                  "{rev.comment}"
                </p>
                <span class="text-[9px] font-mono text-text-muted block text-right">{rev.date}</span>
              </div>
            ))}
          </div>
        </div>

      </div>

    </div>

  </div>
</Layout>

<script is:inline define:vars={{ playlist }}>
  // Study Mode and Checkbox completion logic
  document.addEventListener('DOMContentLoaded', () => {
    const slug = playlist.slug;
    const totalVideos = playlist.videoCount;

    // Log this visit in recentlyVisited
    if (slug) {
      let visited = [];
      try {
        visited = JSON.parse(localStorage.getItem('recentlyVisited') || '[]');
      } catch {
        visited = [];
      }
      visited = visited.filter(item => item.slug !== slug);
      visited.unshift(playlist);
      if (visited.length > 6) visited = visited.slice(0, 6);
      localStorage.setItem('recentlyVisited', JSON.stringify(visited));
    }
    
    const checkboxes = document.querySelectorAll('.video-checkbox');
    const compLabel = document.getElementById('modules-completed-label');
    const percentLabel = document.getElementById('study-percent-label');
    const timeLabel = document.getElementById('time-completed-label');
    const progressMeter = document.getElementById('progress-meter');

    // Get checked state from localStorage
    function getCompletedVideos() {
      try {
        const completed = JSON.parse(localStorage.getItem('completedVideos') || '{}');
        return completed[slug] || [];
      } catch {
        return [];
      }
    }

    // Save checked state
    function saveCompletedVideos(list) {
      try {
        const completed = JSON.parse(localStorage.getItem('completedVideos') || '{}');
        completed[slug] = list;
        localStorage.setItem('completedVideos', JSON.stringify(completed));
      } catch (err) {
        console.error(err);
      }
    }

    // Refresh UI indicators based on completed videos
    function updateProgressUI() {
      const list = getCompletedVideos();
      
      // Check the boxes matching the list
      checkboxes.forEach(cb => {
        const vidId = cb.getAttribute('data-video-id');
        cb.checked = list.includes(vidId);
      });

      const checkedCount = list.length;
      const percent = totalVideos > 0 ? Math.round((checkedCount / totalVideos) * 100) : 0;

      // Sum up duration
      let completedMins = 0;
      checkboxes.forEach(cb => {
        const vidId = cb.getAttribute('data-video-id');
        if (list.includes(vidId)) {
          const duration = parseInt(cb.getAttribute('data-duration') || '15', 10);
          completedMins += duration;
        }
      });

      // Update elements
      if (compLabel) compLabel.textContent = `${checkedCount} / ${totalVideos}`;
      if (percentLabel) percentLabel.textContent = `${percent}%`;
      if (timeLabel) timeLabel.textContent = `${completedMins} mins`;
      if (progressMeter) progressMeter.style.width = `${percent}%`;

      // Save calculations globally to update total profile figures
      updateGlobalMetrics();
    }

    // Recalculates total watched hours & count across ALL playlists for Dashboard/Profile
    function updateGlobalMetrics() {
      try {
        const completed = JSON.parse(localStorage.getItem('completedVideos') || '{}');
        let totalCount = 0;
        let totalMins = 0;

        // Iterate playlists
        Object.entries(completed).forEach(([pSlug, vids]) => {
          totalCount += vids.length;
          // Estimate 15 mins per video
          totalMins += vids.length * 15;
        });

        const totalHours = Number((totalMins / 60).toFixed(1));
        localStorage.setItem('totalCompletedVideos', totalCount.toString());
        localStorage.setItem('totalHoursWatched', totalHours.toString());
        
        window.dispatchEvent(new CustomEvent('studyMetricsUpdated'));
      } catch (err) {
        console.error(err);
      }
    }

    // Add event listeners on checkboxes
    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        const vidId = cb.getAttribute('data-video-id');
        let list = getCompletedVideos();

        if (cb.checked) {
          if (!list.includes(vidId)) list.push(vidId);
        } else {
          list = list.filter(id => id !== vidId);
        }

        saveCompletedVideos(list);
        updateProgressUI();
      });
    });

    // Handle row clicks to toggle checkbox
    document.querySelectorAll('.video-row').forEach(row => {
      row.addEventListener('click', (e) => {
        // Prevent click trigger if they clicked the anchor link or the input checkbox directly
        if (e.target.closest('a') || e.target.closest('input[type="checkbox"]')) return;
        
        const cb = row.querySelector('.video-checkbox');
        if (cb) {
          cb.checked = !cb.checked;
          cb.dispatchEvent(new Event('change'));
        }
      });
    });

    // Initialize progress indicators
    updateProgressUI();

    // STUDY MODE CONFIG
    const studyToggle = document.getElementById('study-mode-toggle');
    const studyExit = document.getElementById('study-mode-exit');
    const activeBanner = document.getElementById('study-active-banner');
    const header = document.querySelector('header');
    const footer = document.querySelector('footer');
    const hides = document.querySelectorAll('.study-hide');

    function enterStudyMode() {
      hides.forEach(h => {
        h.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => h.classList.add('hidden'), 300);
      });
      if (header) header.classList.add('hidden');
      if (footer) footer.classList.add('hidden');
      if (activeBanner) {
        activeBanner.classList.remove('hidden');
        activeBanner.classList.add('flex');
      }

      // Sync streak counter
      let streak = parseInt(localStorage.getItem('streak') || '0', 10);
      if (streak === 0) {
        localStorage.setItem('streak', '1');
      } else {
        const lastStudy = localStorage.getItem('lastStudyDate');
        const todayStr = new Date().toDateString();
        if (lastStudy !== todayStr) {
          localStorage.setItem('streak', (streak + 1).toString());
          localStorage.setItem('lastStudyDate', todayStr);
        }
      }
    }

    function exitStudyMode() {
      hides.forEach(h => {
        h.classList.remove('hidden');
        setTimeout(() => h.classList.remove('opacity-0', 'pointer-events-none'), 50);
      });
      if (header) header.classList.remove('hidden');
      if (footer) footer.classList.remove('hidden');
      if (activeBanner) {
        activeBanner.classList.add('hidden');
        activeBanner.classList.remove('flex');
      }
    }

    if (studyToggle) studyToggle.addEventListener('click', enterStudyMode);
    if (studyExit) studyExit.addEventListener('click', exitStudyMode);
  });
</script>
