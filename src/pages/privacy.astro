---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": "https://youtubeplaylistfinder.com/privacy" }
  ]
};
---

<Layout 
  title="Privacy Policy | youtubeplaylistfinder"
  description="Read our YouTube Data API compliant Privacy Policy. Understand our data practices, cookie policy, and user rights."
  canonical="https://youtubeplaylistfinder.com/privacy"
  schema={breadcrumbs}
>
  <!-- Scroll Progress Indicator -->
  <div class="fixed top-0 left-0 w-full h-1 z-[60] bg-zinc-950">
    <div id="scroll-bar" class="h-full bg-accent w-0 transition-all duration-75"></div>
  </div>

  <div class="flex flex-col lg:flex-row gap-10 mt-6 relative items-start">
    <!-- Sticky Table of Contents -->
    <aside class="w-full lg:w-64 shrink-0 lg:sticky lg:top-24 space-y-4 order-2 lg:order-1 glass-panel p-6 rounded-2xl border border-white/5">
      <h3 class="text-xs font-mono uppercase tracking-wider text-white border-b border-white/10 pb-2">Table of Contents</h3>
      <nav class="space-y-2 text-xs font-mono">
        <a href="#introduction" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">Introduction</a>
        <a href="#youtube-api" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">YouTube API Services</a>
        <a href="#data-collection" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">Data Collection</a>
        <a href="#api-usage" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">API Usage Policy</a>
        <a href="#cookies" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">Cookie Policy</a>
        <a href="#retention" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">Data Retention</a>
        <a href="#rights" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">User Rights</a>
        <a href="#compliance" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">Google Compliance</a>
        <a href="#contact" class="block text-text-secondary hover:text-white transition-colors duration-150 py-1 border-l-2 border-transparent pl-3 [&.active]:border-accent [&.active]:text-white">Contact Us</a>
      </nav>
    </aside>

    <!-- Main Content Area -->
    <article class="flex-1 space-y-12 order-1 lg:order-2 glass-panel p-8 md:p-10 rounded-3xl border border-white/5 bg-zinc-950/20 backdrop-blur-md">
      <header class="border-b border-white/5 pb-6">
        <span class="text-[10px] font-mono uppercase tracking-wider text-accent font-semibold">Legal Documentation</span>
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white mt-1">Privacy Policy</h1>
        <p class="text-xs text-text-secondary mt-2">Last updated: July 1, 2026</p>
      </header>

      <div class="space-y-8 text-sm text-text-secondary leading-relaxed">
        
        <!-- Introduction -->
        <section id="introduction" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">01.</span> Introduction
          </h2>
          <p>
            Welcome to youtubeplaylistfinder.com. We respect your privacy and are committed to protecting any information we access or handle. This Privacy Policy outlines the types of metrics, details, and data logged, processed, or accessed during your visits and interactions with our application.
          </p>
          <p>
            Please read this policy carefully. If you do not agree with the terms outlined herein, please discontinue your use of our services.
          </p>
        </section>

        <!-- YouTube API Services -->
        <section id="youtube-api" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">02.</span> YouTube API Services
          </h2>
          <p class="font-semibold text-white">
            This application uses YouTube API Services.
          </p>
          <p>
            By using this application, you agree to be bound by the <a href="https://www.youtube.com/t/terms" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">YouTube Terms of Service</a> and agree to the <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Google Privacy Policy</a>. We encourage you to review their terms and policies to understand how Google processes user data.
          </p>
          <p>
            We also strictly adhere to the <a href="https://developers.google.com/terms/api-services-user-data-policy" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Google API Services User Data Policy</a>, ensuring user data privacy and security are maintained to the highest standards.
          </p>
        </section>

        <!-- Data Collection -->
        <section id="data-collection" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">03.</span> Data Collection
          </h2>
          <p>
            We only access or process data necessary to provide and optimize the playlist discovery platform. Below are details of the data types processed:
          </p>
          <div class="glass-panel p-6 rounded-2xl border border-white/5 bg-black/40 space-y-4">
            <h4 class="text-xs uppercase font-mono text-white tracking-wider">Metrics processed:</h4>
            <ul class="list-disc pl-5 space-y-2 text-xs">
              <li><strong>Search Queries</strong>: Search terms entered in the application to find playlists on YouTube.</li>
              <li><strong>Playlist & Video Identifiers</strong>: Slugs and YouTube IDs of playlists and individual videos required to fetch layout schema.</li>
              <li><strong>Device & Browser Information</strong>: Anonymized user agents, operating systems, and viewport dimensions to optimize responsiveness and display settings.</li>
              <li><strong>IP Addresses & Server Logs</strong>: Standard hosting metrics collected for firewall configuration, security audits, and rate-limiting.</li>
              <li><strong>Usage Analytics</strong>: Page dwell times, navigation flow, and click patterns to assess performance and Core Web Vitals.</li>
            </ul>
          </div>
          <div class="p-5 rounded-2xl bg-accent/5 border border-accent/15 space-y-2">
            <h4 class="text-xs uppercase font-mono text-accent font-semibold tracking-wider">Data Guarantees:</h4>
            <ul class="list-none space-y-1.5 text-xs text-text-secondary">
              <li class="flex items-center gap-2">
                <span class="text-accent">✓</span> We never collect or request YouTube passwords.
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent">✓</span> We never collect or request Google account credentials.
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent">✓</span> We never access or store private YouTube content (only public data is accessed).
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent">✓</span> We never sell user information to any third parties.
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent">✓</span> We only access publicly available YouTube data returned by the YouTube Data API.
              </li>
            </ul>
          </div>
        </section>

        <!-- API Usage Policy -->
        <section id="api-usage" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">04.</span> API Usage Policy
          </h2>
          <p>
            The application uses YouTube Data API Services solely to provide, support, and enhance search and playlist analysis functions for educational and self-study purposes.
          </p>
          <p>
            We do not use any API data for marketing or advertisements, nor do we build advertising profiles. We do not share accessed API data with any third-party services, except with Google as required to fetch public details from official endpoints.
          </p>
        </section>

        <!-- Cookie Policy -->
        <section id="cookies" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">05.</span> Cookie Policy
          </h2>
          <p>
            Cookies and local browser storage (such as `localStorage`) are used strictly to maintain essential features and compile performance metrics. Cookies are used for:
          </p>
          <ul class="list-disc pl-5 space-y-2 text-xs">
            <li><strong>Session Management</strong>: Ensuring basic application status and routing operate correctly.</li>
            <li><strong>User Preferences</strong>: Bookmarking saved study playlists, marking videos as read, and storing streak metrics locally in your browser.</li>
            <li><strong>Analytics & Diagnostics</strong>: Compiling page load statistics to diagnose errors.</li>
          </ul>
        </section>

        <!-- Data Retention -->
        <section id="retention" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">06.</span> Data Retention
          </h2>
          <p>
            Search logs are stored only for diagnostic purposes and are automatically pruned. Cached YouTube API details are kept temporarily inside memory or Cloudflare KV caches to prevent rate-limit exhaustion and are updated regularly. 
          </p>
          <p>
            Since we do not require accounts, you can clear all local configuration files, visited page history, and checklists directly by wiping your browser's site cookies and storage data.
          </p>
        </section>

        <!-- User Rights -->
        <section id="rights" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">07.</span> User Rights
          </h2>
          <p>
            You have the right to request deletion of any stored data. If you have concerns, need clarification, or want to verify if any metrics have been linked to your browser fingerprint, you can request data audits or complete erasure at any time.
          </p>
        </section>

        <!-- Google Compliance Disclaimers -->
        <section id="compliance" class="scroll-mt-24 space-y-4 border-t border-white/5 pt-6">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">08.</span> Google Compliance
          </h2>
          <div class="p-5 rounded-2xl bg-zinc-900 border border-white/5 text-xs space-y-3 font-mono">
            <p>
              "This application uses YouTube API Services."
            </p>
            <p>
              "This application is not affiliated with, endorsed by, sponsored by, or certified by Google LLC or YouTube."
            </p>
          </div>
        </section>

        <!-- Contact Us -->
        <section id="contact" class="scroll-mt-24 space-y-4">
          <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
            <span class="text-accent font-mono text-xs">09.</span> Contact Us
          </h2>
          <p>
            For questions, requests, or comments regarding this policy, please contact us:
          </p>
          <div class="glass-panel p-6 rounded-2xl border border-white/5 space-y-2 text-xs">
            <p><strong>Email</strong>: <a href="mailto:youtubeplaylistfinder100@gmail.com" class="text-accent hover:underline">youtubeplaylistfinder100@gmail.com</a></p>
            <p><strong>Website</strong>: <a href="https://youtubeplaylistfinder.com" class="text-accent hover:underline">https://youtubeplaylistfinder.com</a></p>
          </div>
        </section>

      </div>
    </article>
  </div>
</Layout>

<script>
  // Scroll Progress Indicator
  const scrollBar = document.getElementById('scroll-bar');
  window.addEventListener('scroll', () => {
    const totalScroll = document.documentElement.scrollHeight - window.innerHeight;
    if (totalScroll > 0) {
      const percentage = (window.scrollY / totalScroll) * 100;
      if (scrollBar) scrollBar.style.width = `${percentage}%`;
    }
  });

  // Table of Contents Active link highlighter
  const sections = document.querySelectorAll('section[id]');
  const tocLinks = document.querySelectorAll('aside nav a');

  window.addEventListener('scroll', () => {
    let current = '';
    const scrollPos = window.scrollY + 120; // Offset for stickiness

    sections.forEach((section) => {
      const top = (section as HTMLElement).offsetTop;
      const height = (section as HTMLElement).offsetHeight;
      if (scrollPos >= top && scrollPos < top + height) {
        current = section.getAttribute('id') || '';
      }
    });

    tocLinks.forEach((link) => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('active');
      }
    });
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
  /* Custom Active styling matching theme */
  .active {
    color: var(--color-accent, #ffffff) !important;
    border-color: var(--color-accent, #3b82f6) !important;
    background-color: rgba(255, 255, 255, 0.02);
  }
</style>
