---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Terms & Conditions", "item": "https://youtubeplaylistfinder.com/terms-and-conditions" }
  ]
};
---

<Layout 
  title="Terms & Conditions | youtubeplaylistfinder"
  description="Read the terms of service for youtubeplaylistfinder.com. Understand usage guidelines, disclaimers, and liabilities."
  canonical="https://youtubeplaylistfinder.com/terms-and-conditions"
  schema={breadcrumbs}
>
  <div class="max-w-4xl mx-auto space-y-8 text-left leading-relaxed">
    <section class="border-b border-white/5 pb-6">
      <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted">Legal Terms</span>
      <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Terms & Conditions</h1>
      <p class="text-xs text-text-secondary mt-1">Last updated: June 30, 2026</p>
    </section>

    <div class="space-y-6 text-xs text-text-secondary">
      <p>
        Welcome to youtubeplaylistfinder.com. By accessing or using our website, you agree to comply with and be bound by the following terms of use. Please read them carefully.
      </p>

      <div class="space-y-2">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider font-mono">1. Acceptance of Terms</h2>
        <p>
          These Terms govern your access to and use of youtubeplaylistfinder.com (the "Service"). By using the Service, you signify your agreement to these Terms. If you do not agree, you are prohibited from using the platform.
        </p>
      </div>

      <div class="space-y-2">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider font-mono">2. Curation & Quality Rankings Disclaimer</h2>
        <p>
          Our Quality Scores and ratings are compiled using public parameters (reviews, counts, author metrics) via a proprietary weighting system.
        </p>
        <p>
          These scores represent recommendations for educational purposes and are provided "as-is" without warranty. We do not guarantee the completeness, accuracy, or learning effectiveness of any external playlist. Learning outcomes are the sole responsibility of the student.
        </p>
      </div>

      <div class="space-y-2">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider font-mono">3. External Links & YouTube Services</h2>
        <p>
          The Service links to external content hosted on YouTube.com. We do not host, own, or control YouTube videos. We are not responsible for modifications, deletions, or policy compliance issues affecting external playlists. Users are bound by YouTube's terms of service when viewing content on YouTube.
        </p>
      </div>

      <div class="space-y-2">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider font-mono">4. Permitted Website Usage</h2>
        <p>
          You are granted a limited license to browse courses, compile study checklists, and generate AI roadmaps. You agree not to:
        </p>
        <ul class="list-disc pl-5 space-y-1">
          <li>Scrape platform search details systematically using automated bots.</li>
          <li>Incorporate website templates in external commercial applications.</li>
          <li>Bypass security protocols or overload site hosting bandwidth.</li>
        </ul>
      </div>

      <div class="space-y-2">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider font-mono">5. Limitation of Liability</h2>
        <p>
          In no event shall youtubeplaylistfinder or its developers be liable for damages (including data loss, hardware errors, or study setbacks) arising out of the use or inability to use the platform templates.
        </p>
      </div>
    </div>
  </div>
</Layout>
