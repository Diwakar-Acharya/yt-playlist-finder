---
import Layout from '../layouts/Layout.astro';
import PlaylistCard from '../components/PlaylistCard.astro';
import { searchPlaylists } from '../lib/api';
import { getCloudflareEnv } from '../lib/youtube';
import { Award } from '@lucide/astro';

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

// Fetch and validate playlists on server
const playlists = await searchPlaylists('', {}, 'best', apiKey, env);

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Top Playlists", "item": "https://youtubeplaylistfinder.com/top-playlists" }
  ]
};
---

<Layout 
  title="Top Scored YouTube Playlists - Global rankings | youtubeplaylistfinder"
  description="Explore the global leaderboard of the highest-rated study YouTube playlists, based on structured lesson paths and authority scores."
  canonical="https://youtubeplaylistfinder.com/top-playlists"
  schema={breadcrumbs}
>
  <div class="space-y-12">
    <!-- Header -->
    <section class="border-b border-white/5 pb-6">
      <div class="flex items-center gap-2">
        <Award class="w-5 h-5 text-accent" />
        <div>
          <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted font-semibold">Global Leaderboard</span>
          <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Top Ranked Playlists</h1>
        </div>
      </div>
      <p class="text-xs text-text-secondary mt-2">The highest-scoring educational curricula on YouTube audited across five performance signals.</p>
    </section>

    <!-- Leaderboard grids -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.map((playlist, idx) => (
        <div class="relative h-full">
          <div class="absolute top-3 right-12 z-30 px-2.5 py-1 rounded-md bg-black/85 border border-white/10 text-xs font-mono font-bold text-accent shadow-lg pointer-events-none">
            Rank #{idx + 1}
          </div>
          <PlaylistCard playlist={playlist} />
        </div>
      ))}
    </div>
  </div>
</Layout>
