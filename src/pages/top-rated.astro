---
import Layout from '../layouts/Layout.astro';
import PlaylistCard from '../components/PlaylistCard.astro';
import { searchPlaylists } from '../lib/api';
import { getCloudflareEnv } from '../lib/youtube';
import { Star } from '@lucide/astro';

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

// Fetch and validate playlists on server
const playlists = await searchPlaylists('', {}, 'best', apiKey, env);

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Top Rated", "item": "https://youtubeplaylistfinder.com/top-rated" }
  ]
};
---

<Layout 
  title="Top Rated Study Playlists - Learner Satisfaction | youtubeplaylistfinder"
  description="Explore the best rated YouTube playlists. Discover courses backed by outstanding community reviews, high completion rates, and learning effectiveness."
  canonical="https://youtubeplaylistfinder.com/top-rated"
  schema={breadcrumbs}
>
  <div class="space-y-12">
    <!-- Header -->
    <section class="border-b border-white/5 pb-6">
      <div class="flex items-center gap-2">
        <Star class="w-5 h-5 text-yellow-500 fill-yellow-500/20 animate-pulse" />
        <div>
          <span class="text-[10px] font-mono uppercase tracking-wider text-yellow-500 font-semibold">User Satisfaction</span>
          <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Top Rated Study Tracks</h1>
        </div>
      </div>
      <p class="text-xs text-text-secondary mt-2">Playlists with outstanding learner reviews and structured syllabi to start learning faster.</p>
    </section>

    <!-- Playlist list grids -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.map(playlist => (
        <PlaylistCard playlist={playlist} />
      ))}
    </div>
  </div>
</Layout>
