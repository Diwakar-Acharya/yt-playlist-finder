---
import Layout from '../../../layouts/Layout.astro';
import PlaylistCard from '../../../components/PlaylistCard.astro';
import { searchPlaylists } from '../../../lib/api';
import { getCloudflareEnv } from '../../../lib/youtube';
import { ChevronLeft } from '@lucide/astro';

const { topic } = Astro.params;
if (!topic) {
  return Astro.redirect('/404');
}

const cleanTopic = topic.trim().replace(/-/g, ' ');
const titleCaseTopic = cleanTopic.charAt(0).toUpperCase() + cleanTopic.slice(1);

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

const playlists = await searchPlaylists(cleanTopic, { difficulty: 'Beginner' }, 'best', apiKey, env);

// Breadcrumb Schema
const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": titleCaseTopic, "item": `https://youtubeplaylistfinder.com/topic/${topic}` },
    { "@type": "ListItem", "position": 3, "name": "Beginner Guides", "item": `https://youtubeplaylistfinder.com/topic/${topic}/beginner` }
  ]
};
---

<Layout 
  title={`Best Beginner ${titleCaseTopic} YouTube Playlists | youtubeplaylistfinder`}
  description={`Discover introductory beginner-level YouTube playlists for learning ${titleCaseTopic}. Check out Quality Scores, structured syllabi, and study checklists.`}
  canonical={`https://youtubeplaylistfinder.com/topic/${topic}/beginner`}
  schema={breadcrumbs}
>
  <div class="space-y-8">
    <div>
      <a href={`/topic/${topic}`} class="inline-flex items-center gap-1 text-xs text-text-secondary hover:text-white transition-colors">
        <ChevronLeft class="w-4 h-4" /> Back to {titleCaseTopic} index
      </a>
    </div>

    <section class="border-b border-white/5 pb-6">
      <span class="text-[10px] font-mono uppercase tracking-wider text-emerald-400">Difficulty: Beginner level</span>
      <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Introductory {titleCaseTopic} Playlists</h1>
      <p class="text-xs text-text-secondary mt-1">Starting from absolute scratch? These playlists focus on foundations, core syntax, environment setup, and basic walkthroughs.</p>
    </section>

    <!-- Playlist list grids -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.length === 0 ? (
        <div class="col-span-full py-16 text-center border border-dashed border-white/5 rounded-2xl">
          <h3 class="text-sm font-semibold text-white">No beginner playlists found for {titleCaseTopic}</h3>
          <p class="text-xs text-text-muted mt-1 max-w-sm mx-auto">We couldn't locate any beginner courses right now. Go back to homepage and search to scrape them live.</p>
        </div>
      ) : (
        playlists.map(playlist => (
          <PlaylistCard playlist={playlist} />
        ))
      )}
    </div>
  </div>
</Layout>
