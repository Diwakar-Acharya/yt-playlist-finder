---
import Layout from '../../../layouts/Layout.astro';
import { searchPlaylists, getPlaylistBySlug } from '../../../lib/api';
import { getChannelUrl } from '../../../lib/youtube';
import { Award, ArrowLeft, Play, Bookmark, CheckCircle2, ChevronRight, HelpCircle } from '@lucide/astro';

const { topic } = Astro.params;
if (!topic) {
  return Astro.redirect('/404');
}

const cleanTopic = topic.trim().replace(/-/g, ' ');
const titleCaseTopic = cleanTopic.charAt(0).toUpperCase() + cleanTopic.slice(1);

const playlists = await searchPlaylists(cleanTopic);
// Find the single highest scoring playlist
const bestPlaylist = playlists.length > 0 ? [...playlists].sort((a, b) => b.score - a.score)[0] : null;

// Populate detail videos if they are missing
let hydratedPlaylist = null;
if (bestPlaylist) {
  const check = await getPlaylistBySlug(bestPlaylist.slug);
  hydratedPlaylist = check || bestPlaylist;
}

// Schemas: Breadcrumbs, FAQ, and Course Schema
const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": titleCaseTopic, "item": `https://youtubeplaylistfinder.com/topic/${topic}` },
    { "@type": "ListItem", "position": 3, "name": "Best Playlist", "item": `https://youtubeplaylistfinder.com/topic/${topic}/best-playlist` }
  ]
};

const courseSchema = hydratedPlaylist ? {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": hydratedPlaylist.title,
  "description": hydratedPlaylist.description,
  "provider": {
    "@type": "Organization",
    "name": hydratedPlaylist.channel,
    "sameAs": getChannelUrl(hydratedPlaylist.channel)
  }
} : null;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Which is the best YouTube playlist to learn ${titleCaseTopic}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": hydratedPlaylist 
          ? `Based on our quality ranking system, the best YouTube playlist for learning ${titleCaseTopic} is "${hydratedPlaylist.title}" by channel "${hydratedPlaylist.channel}", scoring ${hydratedPlaylist.score} out of 100.` 
          : `We mathematically rank and index playlist metrics (structure, authority, user reviews) to determine the best tutorial playlist for learning ${titleCaseTopic}.`
      }
    }
  ]
};

const activeSchemas = [breadcrumbs, faqSchema];
if (courseSchema) activeSchemas.push(courseSchema as any);
---

<Layout 
  title={`Best ${titleCaseTopic} YouTube Playlist (Highest Quality Score) | youtubeplaylistfinder`}
  description={`Find out why the syllabus playlist by ${hydratedPlaylist?.channel || 'top creators'} is ranked the best study playlist to learn ${titleCaseTopic} online.`}
  canonical={`https://youtubeplaylistfinder.com/topic/${topic}/best-playlist`}
  schema={activeSchemas}
>
  <div class="space-y-8">
    <!-- Back link -->
    <div>
      <a href={`/topic/${topic}`} class="inline-flex items-center gap-1 text-xs text-text-secondary hover:text-white transition-colors">
        <ArrowLeft class="w-4 h-4" /> Back to {titleCaseTopic} listings
      </a>
    </div>

    {!hydratedPlaylist ? (
      <div class="glass-panel rounded-2xl p-12 text-center max-w-md mx-auto">
        <h3 class="text-sm font-semibold text-white">No active course found</h3>
        <p class="text-xs text-text-muted mt-1">We couldn't compile the spotlight course details. Return to homepage and query to pull matching channels.</p>
      </div>
    ) : (
      <div class="space-y-12">
        <!-- Spotlight Card -->
        <section class="glass-panel border-t-2 border-t-accent rounded-3xl p-6 md:p-10 relative overflow-hidden">
          <div class="absolute right-0 top-0 bottom-0 w-1/3 opacity-15 hidden md:block">
            <img src={hydratedPlaylist.thumbnail} alt="" class="w-full h-full object-cover blur-sm" />
            <div class="absolute inset-0 bg-gradient-to-r from-black to-transparent"></div>
          </div>

          <div class="relative z-10 max-w-3xl space-y-4">
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full border border-accent/30 bg-accent/5 text-[10px] font-mono text-accent font-bold uppercase tracking-wider">
              <Award class="w-3.5 h-3.5" /> Highest Scored Spotlight • Rank 1
            </span>
            
            <h1 class="text-2xl md:text-4xl font-bold tracking-tight text-white leading-tight">
              {hydratedPlaylist.title}
            </h1>
            
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed max-w-2xl">
              {hydratedPlaylist.description}
            </p>

            <div class="flex flex-wrap items-center gap-4 text-xs font-mono text-text-muted pt-2">
              <span>Channel: <a href={getChannelUrl(hydratedPlaylist.channel)} target="_blank" rel="noopener noreferrer" class="text-white hover:text-accent transition-colors underline inline-flex items-center gap-0.5 font-bold">{hydratedPlaylist.channel}</a></span>
              <span>•</span>
              <span>{hydratedPlaylist.videoCount} Lectures</span>
              <span>•</span>
              <span>{hydratedPlaylist.durationHours} Hours</span>
              <span>•</span>
              <span class="text-accent">Quality Score: {hydratedPlaylist.score}/100</span>
            </div>

            <div class="pt-6 flex flex-wrap gap-4">
              <a 
                href={`/playlist/${hydratedPlaylist.slug}`} 
                class="px-5 py-2.5 rounded-xl bg-white hover:bg-zinc-200 text-black text-xs font-semibold flex items-center gap-1.5 transition-all hover:scale-98 shadow-lg"
              >
                <Play class="w-3.5 h-3.5 fill-black" /> Begin Course Outline
              </a>
              <button 
                class="px-5 py-2.5 rounded-xl border border-white/10 hover:bg-zinc-900 text-text-secondary hover:text-white text-xs font-semibold flex items-center gap-1.5 transition-colors cursor-pointer"
              >
                <Bookmark class="w-3.5 h-3.5" /> Save Course
              </button>
            </div>
          </div>
        </section>

        <!-- Syllabus Outline (if populated) -->
        {hydratedPlaylist.videos && hydratedPlaylist.videos.length > 0 && (
          <div class="glass-panel rounded-2xl p-6 md:p-8 space-y-4">
            <h3 class="text-sm font-mono uppercase text-white tracking-wider">Spotlight Course Syllabus</h3>
            <div class="space-y-3">
              {hydratedPlaylist.videos.map((vid, idx) => (
                <div class="flex items-center justify-between p-3 rounded-xl border border-white/5 bg-zinc-950/40 text-xs font-mono text-text-secondary">
                  <div class="flex items-center gap-3">
                    <span class="text-accent">{idx + 1}</span>
                    <span class="text-white font-bold line-clamp-1">{vid.title}</span>
                  </div>
                  <span class="text-text-muted">{vid.duration} mins</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- FAQs for rich snippet search results integration -->
        <section class="max-w-3xl space-y-4">
          <h3 class="text-lg font-bold tracking-tight text-white flex items-center gap-2">
            <HelpCircle class="w-4 h-4 text-accent" /> Frequently Asked Questions
          </h3>
          
          <div class="glass-panel rounded-2xl p-6 space-y-4">
            <div>
              <h4 class="text-sm font-semibold text-white flex items-center gap-2">
                <ChevronRight class="w-3.5 h-3.5 text-accent" /> How was this playlist determined to be the best?
              </h4>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed pl-5">
                Our algorithm processes structured data checks: playlist completeness, channel authority indices, active user feedback reviews, update frequency, and structural syllabus mapping to select the highest-scoring course.
              </p>
            </div>
          </div>
        </section>
      </div>
    )}
  </div>
</Layout>
