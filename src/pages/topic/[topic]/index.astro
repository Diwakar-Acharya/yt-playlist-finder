---
import Layout from '../../../layouts/Layout.astro';
import PlaylistCard from '../../../components/PlaylistCard.astro';
import { searchPlaylists } from '../../../lib/api';
import { getCloudflareEnv } from '../../../lib/youtube';
import { Sparkles, Award, Layers } from '@lucide/astro';

const { topic } = Astro.params;
if (!topic) {
  return Astro.redirect('/404');
}

const cleanTopic = topic.trim().replace(/-/g, ' ');
const titleCaseTopic = cleanTopic.charAt(0).toUpperCase() + cleanTopic.slice(1);

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

// Fetch playlists dynamically (queries both database and YouTube live scraper)
const playlists = await searchPlaylists(cleanTopic, {}, 'best', apiKey, env);

// Schema Breadcrumbs & List Items for SEO crawlers
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://youtubeplaylistfinder.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Topics",
      "item": "https://youtubeplaylistfinder.com/roadmaps"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": titleCaseTopic,
      "item": `https://youtubeplaylistfinder.com/topic/${topic}`
    }
  ]
};

const playlistListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Top Scored ${titleCaseTopic} Playlists`,
  "numberOfItems": playlists.length,
  "itemListElement": playlists.map((p, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "url": `https://youtubeplaylistfinder.com/playlist/${p.slug}`,
    "name": p.title
  }))
};
---

<Layout 
  title={`Best YouTube Playlists for ${titleCaseTopic} - ranked courses | youtubeplaylistfinder`}
  description={`Discover mathematically ranked and graded YouTube playlists for learning ${titleCaseTopic}. Access direct links, structured roadmaps, and student reviews.`}
  canonical={`https://youtubeplaylistfinder.com/topic/${topic}`}
  schema={[breadcrumbSchema, playlistListSchema]}
>
  <div class="space-y-8">
    
    <!-- Topic Segment Header -->
    <section class="border-b border-white/5 pb-6">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <span class="text-[10px] font-mono uppercase tracking-wider text-text-muted font-semibold">Learning Topic</span>
          <h1 class="text-3xl font-bold tracking-tight text-white mt-1">{titleCaseTopic} Study Tracks</h1>
          <p class="text-xs text-text-secondary mt-1">Syllabus-mapped study paths to learn {cleanTopic} from scratch.</p>
        </div>
        
        <!-- Segment routes links for internal SEO link juice -->
        <div class="flex flex-wrap gap-2 pt-2 md:pt-0">
          <a href={`/topic/${topic}/best-playlist`} class="px-3.5 py-1.5 rounded-xl border border-accent/30 bg-accent/5 hover:bg-accent/15 text-accent text-xs font-semibold flex items-center gap-1 transition-colors">
            <Award class="w-3.5 h-3.5" /> Best Playlist Spotlight
          </a>
          <a href={`/topic/${topic}/beginner`} class="px-3.5 py-1.5 rounded-xl border border-white/10 hover:bg-zinc-900 text-text-secondary hover:text-white text-xs font-semibold flex items-center gap-1 transition-colors">
            <Layers class="w-3.5 h-3.5" /> Beginner Guides
          </a>
          <a href={`/topic/${topic}/advanced`} class="px-3.5 py-1.5 rounded-xl border border-white/10 hover:bg-zinc-900 text-text-secondary hover:text-white text-xs font-semibold flex items-center gap-1 transition-colors">
            <Sparkles class="w-3.5 h-3.5" /> Advanced Courses
          </a>
        </div>
      </div>
    </section>

    <!-- Playlist list grids -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.length === 0 ? (
        <div class="col-span-full py-16 text-center border border-dashed border-white/5 rounded-2xl">
          <h3 class="text-sm font-semibold text-white">No playlists found for {titleCaseTopic}</h3>
          <p class="text-xs text-text-muted mt-1 max-w-sm mx-auto">We couldn't locate any matching courses right now. Go back to homepage and search to scrape them live.</p>
          <a href="/" class="mt-4 inline-block text-xs text-accent font-semibold hover:underline">Return to Search →</a>
        </div>
      ) : (
        playlists.map(playlist => (
          <PlaylistCard playlist={playlist} />
        ))
      )}
    </div>
  </div>
</Layout>
