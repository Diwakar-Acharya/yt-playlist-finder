---
import Layout from '../layouts/Layout.astro';
import PlaylistCard from '../components/PlaylistCard.astro';
import { searchPlaylists } from '../lib/api';
import { getCloudflareEnv } from '../lib/youtube';
import { Flame } from '@lucide/astro';

const env = await getCloudflareEnv();
const apiKey = env?.YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY || '';

// Fetch and validate playlists on server
const playlists = await searchPlaylists('', {}, 'best', apiKey, env);

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://youtubeplaylistfinder.com/" },
    { "@type": "ListItem", "position": 2, "name": "Trending", "item": "https://youtubeplaylistfinder.com/trending" }
  ]
};
---

<Layout 
  title="Trending YouTube Playlists - Weekly Leaderboard | youtubeplaylistfinder"
  description="Discover the weekly trending study YouTube playlists. View the top-voted video courses in programming, science, and design."
  canonical="https://youtubeplaylistfinder.com/trending"
  schema={breadcrumbs}
>
  <div class="space-y-12">
    <!-- Header -->
    <section class="border-b border-white/5 pb-6">
      <div class="flex items-center gap-2">
        <span class="p-1 rounded bg-orange-950/30 border border-orange-500/20 text-orange-500">
          <Flame class="w-5 h-5 fill-orange-500/10 animate-pulse" />
        </span>
        <div>
          <span class="text-[10px] font-mono uppercase tracking-wider text-orange-500 font-semibold">Weekly Hotlist</span>
          <h1 class="text-3xl font-bold tracking-tight text-white mt-1">Trending Learning Playlists</h1>
        </div>
      </div>
      <p class="text-xs text-text-secondary mt-2">The most bookmarked and completed video curricula active in our self-education catalog today.</p>
    </section>

    <!-- Leaderboard cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {playlists.map(playlist => (
        <PlaylistCard playlist={playlist} />
      ))}
    </div>
  </div>
</Layout>
